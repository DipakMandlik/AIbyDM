---
import LearnSectionNav from '@components/learn/LearnSectionNav.astro';
import SearchExperience from '@components/learn/SearchExperience';
import BaseLayout from '@layouts/BaseLayout.astro';

const initialQuery = Astro.url.searchParams.get('q') ?? '';
---

<BaseLayout
  title="Search - AIByDM"
  description="Search tracks, lessons, projects, resources, and glossary entries across the AIByDM learn platform."
>
  <section class="mx-auto max-w-7xl px-4 pt-10 sm:px-6 lg:px-8 lg:pt-14">
    <LearnSectionNav active="search" />
  </section>
  <SearchExperience client:load initialQuery={initialQuery} />
</BaseLayout>
