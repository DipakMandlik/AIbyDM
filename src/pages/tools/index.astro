---
import { getCollection } from 'astro:content';
import { Cpu, ExternalLink, GitPullRequest, Scale, Tags } from 'lucide-react';

import BaseLayout from '@layouts/BaseLayout.astro';

const entries = await getCollection('tools');
const tools = entries.sort((a, b) => a.data.name.localeCompare(b.data.name));
const categories = [...new Set(tools.map((tool) => tool.data.category))];
const openSourceCount = tools.filter((tool) => tool.data.openSource).length;
const featuredCount = tools.filter((tool) => tool.data.featured).length;
const repoIssueUrl = 'https://github.com/DipakMandlik/AIbyDM/issues/new/choose';
---

<BaseLayout
  title="Tools - AIByDM"
  description="Explore AIByDM tool guides for local LLMs, agent frameworks, vector databases, and practical AI engineering infrastructure."
>
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="grid gap-6 lg:grid-cols-[1fr_0.8fr]">
      <div
        class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 sm:p-8"
      >
        <div
          class="inline-flex min-h-11 items-center gap-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-3 text-sm text-[var(--color-text-secondary)]"
        >
          <Cpu className="h-4 w-4 text-[var(--color-tools)]" aria-hidden="true" />
          <span class="font-mono">tools/catalog</span>
        </div>
        <h1
          class="mt-6 max-w-3xl text-4xl leading-tight font-semibold text-[var(--color-text-primary)] sm:text-5xl"
        >
          A build stack learners can actually run.
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-8 text-[var(--color-text-secondary)]">
          Tool entries explain where each project fits in AI engineering: local inference, agent
          orchestration, vector search, licensing, and practical use cases.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
        <div
          class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5"
        >
          <Tags className="h-5 w-5 text-[var(--color-tools)]" aria-hidden="true" />
          <p class="mt-4 font-mono text-sm text-[var(--color-text-tertiary)]">Categories</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--color-text-primary)]">
            {categories.length}
          </p>
        </div>
        <div
          class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5"
        >
          <GitPullRequest className="h-5 w-5 text-[var(--color-tools)]" aria-hidden="true" />
          <p class="mt-4 font-mono text-sm text-[var(--color-text-tertiary)]">Open source</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--color-text-primary)]">
            {openSourceCount}
          </p>
        </div>
        <div
          class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5"
        >
          <Scale className="h-5 w-5 text-[var(--color-tools)]" aria-hidden="true" />
          <p class="mt-4 font-mono text-sm text-[var(--color-text-tertiary)]">Featured</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--color-text-primary)]">
            {featuredCount}
          </p>
        </div>
      </div>
    </div>

    <div class="mt-8 grid gap-4 lg:grid-cols-3">
      {
        tools.map((tool) => (
          <article class="flex min-h-[31rem] flex-col justify-between rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5">
            <div>
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="font-mono text-sm text-[var(--color-tools)]">{tool.data.category}</p>
                  <h2 class="mt-2 text-2xl font-semibold text-[var(--color-text-primary)]">
                    {tool.data.name}
                  </h2>
                </div>
                <span class="rounded-md border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-2 py-1 font-mono text-xs text-[var(--color-text-tertiary)]">
                  {tool.data.license}
                </span>
              </div>
              <p class="mt-4 text-sm leading-7 text-[var(--color-text-secondary)]">
                {tool.data.description}
              </p>

              <div class="mt-5">
                <p class="font-mono text-xs text-[var(--color-text-tertiary)]">Use cases</p>
                <ul class="mt-3 space-y-2">
                  {tool.data.useCases.slice(0, 3).map((useCase) => (
                    <li class="text-sm leading-6 text-[var(--color-text-secondary)]">{useCase}</li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="mt-6 flex flex-wrap gap-2 border-t border-[var(--color-border)] pt-5">
              <a
                href={tool.data.websiteUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="command-button border border-[var(--color-tools)] bg-[var(--color-tools)] text-[var(--color-accent-contrast)] hover:bg-[var(--color-accent-hover)]"
              >
                <ExternalLink className="h-4 w-4" aria-hidden="true" />
                Website
              </a>
              {tool.data.githubUrl && (
                <a
                  href={tool.data.githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="command-button border border-[var(--color-border)] bg-[var(--color-bg-elevated)] text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)]"
                >
                  <GitPullRequest className="h-4 w-4" aria-hidden="true" />
                  Source
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>

    <div
      class="mt-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5 sm:flex sm:items-center sm:justify-between sm:gap-6"
    >
      <div>
        <p class="font-mono text-sm text-[var(--color-tools)]">contribution lane</p>
        <p class="mt-2 text-sm leading-7 text-[var(--color-text-secondary)]">
          Add a tool when it has a clear AI workflow, maintenance signal, license, and practical use
          cases.
        </p>
      </div>
      <a
        href={repoIssueUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="command-button mt-4 border border-[var(--color-border)] bg-[var(--color-bg-elevated)] text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)] sm:mt-0"
      >
        <GitPullRequest className="h-5 w-5" aria-hidden="true" />
        Submit tool
      </a>
    </div>
  </section>
</BaseLayout>
