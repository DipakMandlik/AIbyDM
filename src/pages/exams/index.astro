---
import { getCollection } from 'astro:content';
import { CircleCheck, FileQuestion, GitPullRequest, GraduationCap, ListChecks } from 'lucide-react';

import BaseLayout from '@layouts/BaseLayout.astro';

const entries = await getCollection('exams');
const exams = entries.sort((a, b) => a.data.title.localeCompare(b.data.title));
const questionCount = exams.reduce((total, exam) => total + exam.data.questions.length, 0);
const topics = new Set(
  exams.flatMap((exam) => exam.data.questions.map((question) => question.topic)),
);
const mediumOrHardCount = exams.reduce(
  (total, exam) =>
    total + exam.data.questions.filter((question) => question.difficulty !== 'easy').length,
  0,
);
const repoIssueUrl = 'https://github.com/DipakMandlik/AIByDM/issues/new/choose';
---

<BaseLayout
  title="Exams - AIByDM"
  description="Validate AIByDM learning progress with exam banks, question metadata, explanations, and topic coverage."
>
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="grid gap-6 lg:grid-cols-[1fr_0.85fr]">
      <div
        class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 sm:p-8"
      >
        <div
          class="inline-flex min-h-11 items-center gap-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-3 text-sm text-[var(--color-text-secondary)]"
        >
          <GraduationCap className="h-4 w-4 text-[var(--color-exams)]" aria-hidden="true" />
          <span class="font-mono">exams/question-bank</span>
        </div>
        <h1
          class="mt-6 max-w-3xl text-4xl leading-tight font-semibold text-[var(--color-text-primary)] sm:text-5xl"
        >
          Assessments with explanations, not mystery scores.
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-8 text-[var(--color-text-secondary)]">
          Exams are structured as reusable JSON banks. Every question carries a type, topic,
          difficulty, answer, and explanation so practice can become measurable.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
        <div
          class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5"
        >
          <FileQuestion className="h-5 w-5 text-[var(--color-exams)]" aria-hidden="true" />
          <p class="mt-4 font-mono text-sm text-[var(--color-text-tertiary)]">Questions</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--color-text-primary)]">
            {questionCount}
          </p>
        </div>
        <div
          class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5"
        >
          <ListChecks className="h-5 w-5 text-[var(--color-exams)]" aria-hidden="true" />
          <p class="mt-4 font-mono text-sm text-[var(--color-text-tertiary)]">Topics</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--color-text-primary)]">{topics.size}</p>
        </div>
        <div
          class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5"
        >
          <CircleCheck className="h-5 w-5 text-[var(--color-exams)]" aria-hidden="true" />
          <p class="mt-4 font-mono text-sm text-[var(--color-text-tertiary)]">Medium plus</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--color-text-primary)]">
            {mediumOrHardCount}
          </p>
        </div>
      </div>
    </div>

    <div class="mt-8 grid gap-4">
      {
        exams.map((exam) => (
          <article class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5 sm:p-6">
            <div class="grid gap-6 lg:grid-cols-[1fr_18rem]">
              <div>
                <p class="font-mono text-sm text-[var(--color-exams)]">{exam.data.track}</p>
                <h2 class="mt-2 text-2xl font-semibold text-[var(--color-text-primary)]">
                  {exam.data.title}
                </h2>
                <p class="mt-3 max-w-3xl text-sm leading-7 text-[var(--color-text-secondary)]">
                  {exam.data.description}
                </p>
                <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
                  {exam.data.questions.slice(0, 3).map((question) => (
                    <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4">
                      <p class="font-mono text-xs text-[var(--color-text-tertiary)]">
                        {question.type} / {question.difficulty}
                      </p>
                      <p class="mt-3 text-sm leading-6 text-[var(--color-text-secondary)]">
                        {question.question}
                      </p>
                    </div>
                  ))}
                </div>
              </div>
              <aside class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-5">
                <p class="font-mono text-xs text-[var(--color-text-tertiary)]">Question count</p>
                <p class="mt-2 text-3xl font-semibold text-[var(--color-text-primary)]">
                  {exam.data.questions.length}
                </p>
                <p class="mt-5 font-mono text-xs text-[var(--color-text-tertiary)]">Difficulty</p>
                <p class="mt-2 text-sm text-[var(--color-text-secondary)]">
                  {exam.data.difficulty}
                </p>
                <p class="mt-5 font-mono text-xs text-[var(--color-text-tertiary)]">Topics</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {[...new Set(exam.data.questions.map((question) => question.topic))].map(
                    (topic) => (
                      <span class="rounded-md border border-[var(--color-border)] bg-[var(--color-bg-base)] px-2 py-1 font-mono text-xs text-[var(--color-text-tertiary)]">
                        {topic}
                      </span>
                    ),
                  )}
                </div>
              </aside>
            </div>
          </article>
        ))
      }
    </div>

    <div
      class="mt-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5 sm:flex sm:items-center sm:justify-between sm:gap-6"
    >
      <div>
        <p class="font-mono text-sm text-[var(--color-exams)]">assessment lane</p>
        <p class="mt-2 text-sm leading-7 text-[var(--color-text-secondary)]">
          New exams should include clear explanations, balanced difficulty, and tags that connect
          back to lessons.
        </p>
      </div>
      <a
        href={repoIssueUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="command-button mt-4 border border-[var(--color-border)] bg-[var(--color-bg-elevated)] text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)] sm:mt-0"
      >
        <GitPullRequest className="h-5 w-5" aria-hidden="true" />
        Suggest exam
      </a>
    </div>
  </section>
</BaseLayout>
