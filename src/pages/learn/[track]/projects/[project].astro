---
import {
  ArrowLeft,
  ArrowRight,
  BookOpen,
  CheckCircle2,
  Compass,
  GitBranch,
  Layers3,
  Sparkles,
  Target,
} from 'lucide-react';

import LearnSectionNav from '@components/learn/LearnSectionNav.astro';
import {
  getAllLearningProjects,
  getLessonHref,
  getProjectHref,
  getTrackHref,
  type LearningProjectLevel,
  type LearningProjectMatch,
} from '@data/learn/catalog';
import BaseLayout from '@layouts/BaseLayout.astro';

export function getStaticPaths() {
  return getAllLearningProjects().map((entry) => ({
    params: {
      track: entry.track.slug,
      project: entry.project.slug,
    },
    props: entry,
  }));
}

const { track, project } = Astro.props as LearningProjectMatch;
const allTrackLessons = track.modules.flatMap((moduleEntry) =>
  moduleEntry.lessons.map((lessonEntry) => ({ module: moduleEntry, lesson: lessonEntry })),
);
const readinessLessonCountByLevel: Record<LearningProjectLevel, number> = {
  Beginner: Math.min(1, allTrackLessons.length),
  Intermediate: Math.min(2, allTrackLessons.length),
  Advanced: Math.min(3, allTrackLessons.length),
  Capstone: allTrackLessons.length,
};
const readinessLessons = allTrackLessons.slice(0, readinessLessonCountByLevel[project.level]);
const kickoffLesson = readinessLessons[readinessLessons.length - 1] ?? allTrackLessons[0];
const prepResourceMap = new Map(
  readinessLessons.flatMap(({ lesson }) =>
    lesson.resources.map((resource) => [resource.href, resource] as const),
  ),
);
const prepResources = Array.from(prepResourceMap.values()).slice(0, 4);
const currentProjectIndex = track.projects.findIndex((entry) => entry.slug === project.slug);
const previousProject =
  currentProjectIndex > 0 ? track.projects[currentProjectIndex - 1] : undefined;
const nextProject =
  currentProjectIndex >= 0 && currentProjectIndex < track.projects.length - 1
    ? track.projects[currentProjectIndex + 1]
    : undefined;
const relatedProjects = track.projects.filter((entry) => entry.slug !== project.slug).slice(0, 2);
const learnHomeHref = import.meta.env.BASE_URL + 'learn/';

function readinessBand(level: LearningProjectLevel): string {
  switch (level) {
    case 'Beginner':
      return 'Best once the first lesson is complete.';
    case 'Intermediate':
      return 'Best after the first module clicks.';
    case 'Advanced':
      return 'Best once most of the track feels steady.';
    case 'Capstone':
      return 'Best after the full track is complete.';
    default:
      return 'Start when the track context feels familiar.';
  }
}

function scopeLabel(level: LearningProjectLevel): string {
  switch (level) {
    case 'Beginner':
      return 'Small scoped sprint';
    case 'Intermediate':
      return 'Applied build';
    case 'Advanced':
      return 'Production-shaped drill';
    case 'Capstone':
      return 'Portfolio-ready capstone';
    default:
      return 'Structured project';
  }
}

const projectMilestones = [
  {
    title: 'Frame the workflow',
    detail:
      'Define the user, input, output, and success metric for ' +
      project.title.toLowerCase() +
      ' before you start building.',
  },
  {
    title: 'Assemble the first slice',
    detail:
      'Use ' +
      project.technologies.slice(0, 3).join(' / ') +
      ' to wire the smallest working version of the project.',
  },
  {
    title: 'Pressure-test the behavior',
    detail:
      'Check the system against ' +
      project.outcomes.slice(0, 2).join(' and ') +
      ' while documenting failure modes and tradeoffs.',
  },
  {
    title: 'Ship the artifact',
    detail:
      'Package the final work as ' +
      project.deliverables.join(', ') +
      ' with a short demo narrative and next-iteration backlog.',
  },
];

const reviewRubric = [
  {
    title: 'Problem framing',
    detail:
      'Can another teammate understand the workflow, the goal, and the success criteria from your brief alone?',
  },
  {
    title: 'Execution quality',
    detail:
      'Does the build clearly demonstrate the core skills of ' +
      project.skills.slice(0, 2).join(' and ') +
      '?',
  },
  {
    title: 'Evaluation clarity',
    detail:
      'Have you captured the checks, edge cases, and failure patterns that matter before rollout?',
  },
  {
    title: 'Operational readiness',
    detail:
      'Are the deliverables easy to hand off, demo, iterate on, and extend after the first version ships?',
  },
];
---

<BaseLayout title={project.title + ' - AIByDM Learn'} description={project.summary}>
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <LearnSectionNav active="roadmap" />

    <div class="grid gap-6 lg:grid-cols-[1.08fr_0.92fr] lg:items-start">
      <div
        class="rounded-[32px] border border-[var(--color-border)] bg-[radial-gradient(circle_at_top_left,rgba(56,189,248,0.18),transparent_28%),linear-gradient(180deg,rgba(255,255,255,0.03),transparent),var(--color-bg-surface)] p-6 shadow-[0_24px_90px_rgba(2,8,23,0.28)] sm:p-8 lg:p-10"
      >
        <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--color-text-secondary)]">
          <a href={learnHomeHref} class="transition hover:text-[var(--color-text-primary)]">Learn</a
          >
          <span>/</span>
          <a
            href={getTrackHref(track.slug)}
            class="transition hover:text-[var(--color-text-primary)]"
          >
            {track.title}
          </a>
          <span>/</span>
          <span class="text-[var(--color-text-primary)]">{project.title}</span>
        </div>
        <div class="mt-6 flex flex-wrap gap-2">
          <span
            class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
          >
            {project.level}
          </span>
          <span
            class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
          >
            {project.duration}
          </span>
          <span
            class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
          >
            {project.difficulty}
          </span>
          <span
            class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
          >
            {track.stage} stage
          </span>
        </div>
        <p
          class="mt-6 font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase"
        >
          Project brief
        </p>
        <h1
          class="mt-3 max-w-4xl text-4xl font-semibold tracking-tight text-[var(--color-text-primary)] sm:text-5xl"
        >
          {project.title}
        </h1>
        <p class="mt-4 max-w-3xl text-lg leading-8 text-[var(--color-text-secondary)]">
          {project.summary}
        </p>
        <p class="mt-5 max-w-3xl text-sm leading-8 text-[var(--color-text-secondary)] sm:text-base">
          Turn the {track.title.toLowerCase()} track into a concrete build with a tighter scope, a visible
          artifact, and a clean review loop.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          {
            kickoffLesson && (
              <a
                href={getLessonHref(track.slug, kickoffLesson.lesson.slug)}
                class="command-button border border-transparent bg-[var(--color-accent)] text-[var(--color-accent-contrast)] hover:bg-[var(--color-accent-hover)]"
              >
                <BookOpen className="h-5 w-5" aria-hidden="true" />
                Start the prep runway
              </a>
            )
          }
          <a
            href={getTrackHref(track.slug)}
            class="command-button border border-[var(--color-border)] bg-[var(--color-bg-surface)] text-[var(--color-text-primary)] hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)]"
          >
            <Compass className="h-5 w-5" aria-hidden="true" />
            Back to track roadmap
          </a>
          {
            nextProject && (
              <a
                href={getProjectHref(track.slug, nextProject.slug)}
                class="command-button border border-[var(--color-border)] bg-[var(--color-bg-surface)] text-[var(--color-text-primary)] hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)]"
              >
                Next project
                <ArrowRight className="h-4 w-4" aria-hidden="true" />
              </a>
            )
          }
        </div>
      </div>

      <aside class="space-y-6 lg:sticky lg:top-24">
        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <div class="flex items-center gap-3">
            <Target className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
            <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">Ideal checkpoint</h2>
          </div>
          <div class="mt-5 space-y-3">
            <div
              class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4"
            >
              <p
                class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase"
              >
                Scope
              </p>
              <p class="mt-3 text-lg font-semibold text-[var(--color-text-primary)]">
                {scopeLabel(project.level)}
              </p>
              <p class="mt-2 text-sm leading-7 text-[var(--color-text-secondary)]">
                {readinessBand(project.level)}
              </p>
            </div>
            <div
              class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4"
            >
              <p
                class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase"
              >
                Track context
              </p>
              <p class="mt-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                {track.summary}
              </p>
            </div>
          </div>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <div class="flex items-center gap-3">
            <Layers3 className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
            <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">Tool stack</h2>
          </div>
          <div class="mt-5 flex flex-wrap gap-2">
            {
              project.technologies.map((technology) => (
                <span class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-3 py-1 text-sm text-[var(--color-text-secondary)]">
                  {technology}
                </span>
              ))
            }
            {
              track.tooling.map((tool) => (
                <span class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-3 py-1 text-sm text-[var(--color-text-secondary)]">
                  {tool}
                </span>
              ))
            }
          </div>
        </section>
      </aside>
    </div>

    <div class="mt-8 grid gap-6 lg:grid-cols-[1.08fr_0.92fr] lg:items-start">
      <article class="space-y-6">
        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <div class="flex items-center gap-3">
            <Sparkles className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
            <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">Build brief</h2>
          </div>
          <p class="mt-5 text-sm leading-8 text-[var(--color-text-secondary)] sm:text-base">
            Use this project to practice {project.skills.slice(0, 3).join(', ')} inside a bounded delivery
            loop. The goal is not to overbuild. The goal is to prove the workflow, show the artifact,
            and capture the next iteration clearly.
          </p>
          <div class="mt-5 grid gap-4 md:grid-cols-2">
            <div>
              <p
                class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase"
              >
                Skills learned
              </p>
              <div class="mt-3 flex flex-wrap gap-2">
                {
                  project.skills.map((skill) => (
                    <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-[var(--color-text-secondary)]">
                      {skill}
                    </span>
                  ))
                }
              </div>
            </div>
            <div>
              <p
                class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase"
              >
                Success signals
              </p>
              <ul class="mt-3 space-y-2">
                {
                  project.outcomes.map((outcome) => (
                    <li class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-4 py-3 text-sm text-[var(--color-text-secondary)]">
                      {outcome}
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <div class="flex items-center gap-3">
            <GitBranch className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
            <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">
              Milestone runway
            </h2>
          </div>
          <div class="mt-5 grid gap-3">
            {
              projectMilestones.map((milestone, index) => (
                <div class="rounded-[24px] border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-5">
                  <p class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase">
                    Milestone {String(index + 1).padStart(2, '0')}
                  </p>
                  <h3 class="mt-3 text-lg font-semibold text-[var(--color-text-primary)]">
                    {milestone.title}
                  </h3>
                  <p class="mt-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                    {milestone.detail}
                  </p>
                </div>
              ))
            }
          </div>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <div class="flex items-center gap-3">
            <CheckCircle2 className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
            <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">Deliverables</h2>
          </div>
          <div class="mt-5 grid gap-4 md:grid-cols-2">
            <div>
              <p
                class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase"
              >
                What to ship
              </p>
              <ul class="mt-3 space-y-2">
                {
                  project.deliverables.map((deliverable) => (
                    <li class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-4 py-3 text-sm text-[var(--color-text-secondary)]">
                      {deliverable}
                    </li>
                  ))
                }
              </ul>
            </div>
            <div>
              <p
                class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase"
              >
                How to review it
              </p>
              <ul class="mt-3 space-y-2">
                {
                  reviewRubric.map((item) => (
                    <li class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-4 py-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                      <span class="font-medium text-[var(--color-text-primary)]">{item.title}</span>
                      <span class="mt-1 block">{item.detail}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </section>
      </article>

      <div class="space-y-6 lg:sticky lg:top-24">
        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <div class="flex items-center gap-3">
            <BookOpen className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
            <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">Lesson runway</h2>
          </div>
          <div class="mt-5 space-y-3">
            {
              readinessLessons.map((entry, index) => (
                <a
                  href={getLessonHref(track.slug, entry.lesson.slug)}
                  class="block rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4 transition hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)]"
                >
                  <p class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase">
                    Prep lesson {String(index + 1).padStart(2, '0')} / {entry.module.title}
                  </p>
                  <p class="mt-2 text-base font-semibold text-[var(--color-text-primary)]">
                    {entry.lesson.title}
                  </p>
                  <p class="mt-2 text-sm leading-7 text-[var(--color-text-secondary)]">
                    {entry.lesson.summary}
                  </p>
                </a>
              ))
            }
          </div>
        </section>

        {
          prepResources.length > 0 && (
            <section class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]">
              <div class="flex items-center gap-3">
                <Compass className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
                <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">
                  Prep resources
                </h2>
              </div>
              <div class="mt-5 space-y-3">
                {prepResources.map((resource) => (
                  <a
                    href={resource.href}
                    target="_blank"
                    rel="noreferrer"
                    class="block rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-4 py-3 text-sm text-[var(--color-text-secondary)] transition hover:border-[var(--color-border-hover)] hover:text-[var(--color-text-primary)]"
                  >
                    <span class="font-medium text-[var(--color-text-primary)]">
                      {resource.label}
                    </span>
                    <span class="mt-1 block text-xs tracking-[0.2em] text-[var(--color-text-tertiary)] uppercase">
                      {resource.kind}
                    </span>
                  </a>
                ))}
              </div>
            </section>
          )
        }

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <div class="flex items-center gap-3">
            <Layers3 className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
            <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">Project ladder</h2>
          </div>
          <div class="mt-5 space-y-3">
            {
              previousProject ? (
                <a
                  href={getProjectHref(track.slug, previousProject.slug)}
                  class="flex items-center justify-between gap-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4 transition hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)]"
                >
                  <div>
                    <p class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase">
                      Previous project
                    </p>
                    <p class="mt-2 text-base font-semibold text-[var(--color-text-primary)]">
                      {previousProject.title}
                    </p>
                  </div>
                  <ArrowLeft
                    className="h-4 w-4 text-[var(--color-text-tertiary)]"
                    aria-hidden="true"
                  />
                </a>
              ) : (
                <a
                  href={getTrackHref(track.slug)}
                  class="flex items-center justify-between gap-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4 transition hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)]"
                >
                  <div>
                    <p class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase">
                      Back to track
                    </p>
                    <p class="mt-2 text-base font-semibold text-[var(--color-text-primary)]">
                      {track.title}
                    </p>
                  </div>
                  <ArrowLeft
                    className="h-4 w-4 text-[var(--color-text-tertiary)]"
                    aria-hidden="true"
                  />
                </a>
              )
            }
            {
              nextProject && (
                <a
                  href={getProjectHref(track.slug, nextProject.slug)}
                  class="flex items-center justify-between gap-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4 transition hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)]"
                >
                  <div>
                    <p class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase">
                      Next project
                    </p>
                    <p class="mt-2 text-base font-semibold text-[var(--color-text-primary)]">
                      {nextProject.title}
                    </p>
                  </div>
                  <ArrowRight
                    className="h-4 w-4 text-[var(--color-text-tertiary)]"
                    aria-hidden="true"
                  />
                </a>
              )
            }
            {
              relatedProjects.map((entry) => (
                <a
                  href={getProjectHref(track.slug, entry.slug)}
                  class="block rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4 transition hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)]"
                >
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-[var(--color-text-secondary)]">
                      {entry.level}
                    </span>
                    <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-[var(--color-text-secondary)]">
                      {entry.duration}
                    </span>
                  </div>
                  <p class="mt-3 text-base font-semibold text-[var(--color-text-primary)]">
                    {entry.title}
                  </p>
                  <p class="mt-2 text-sm leading-7 text-[var(--color-text-secondary)]">
                    {entry.summary}
                  </p>
                </a>
              ))
            }
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
