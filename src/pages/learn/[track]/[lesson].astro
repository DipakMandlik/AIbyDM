---
import { getCollection, render } from 'astro:content';
import {
  ArrowLeft,
  ArrowRight,
  BookMarked,
  BookOpen,
  Compass,
  Layers3,
  Sparkles,
} from 'lucide-react';

import LearnSectionNav from '@components/learn/LearnSectionNav.astro';
import LessonProgressButton from '@components/learn/LessonProgressButton';
import LessonRail from '@components/learn/LessonRail';
import {
  getAllLearningLessons,
  getLearningLesson,
  getProjectHref,
  getTrackHref,
} from '@data/learn/catalog';
import BaseLayout from '@layouts/BaseLayout.astro';

export function getStaticPaths() {
  return getAllLearningLessons().map((entry) => ({
    params: {
      track: entry.track.slug,
      lesson: entry.lesson.slug,
    },
  }));
}

const lessonMatch = getLearningLesson(Astro.params.track ?? '', Astro.params.lesson ?? '');
if (!lessonMatch) {
  throw new Error('Learning lesson not found');
}

const { track, module, lesson } = lessonMatch;
const allTrackLessons = track.modules.flatMap((moduleEntry) =>
  moduleEntry.lessons.map((lessonEntry) => ({ module: moduleEntry, lesson: lessonEntry })),
);
const currentIndex = allTrackLessons.findIndex((entry) => entry.lesson.slug === lesson.slug);
const previousLesson = currentIndex > 0 ? allTrackLessons[currentIndex - 1] : undefined;
const nextLesson =
  currentIndex >= 0 && currentIndex < allTrackLessons.length - 1
    ? allTrackLessons[currentIndex + 1]
    : undefined;
const relatedProjects = track.projects.slice(0, 2);

const contentEntries = lesson.contentEntryId ? await getCollection('learn') : [];
const contentEntry = contentEntries.find(
  (entry) =>
    entry.id === lesson.contentEntryId ||
    entry.id.replace(/\\.(md|mdx)$/i, '') === lesson.contentEntryId,
);
const rendered = contentEntry ? await render(contentEntry) : undefined;
const Content = rendered?.Content;
const learnHomeHref = import.meta.env.BASE_URL + 'learn/';
const artifactFormat =
  lesson.format === 'Lab'
    ? 'Workflow notebook'
    : lesson.format === 'Project'
      ? 'Execution brief'
      : lesson.format === 'System Design'
        ? 'Architecture memo'
        : 'Decision note';
const artifactFileName =
  lesson.slug + '-' + artifactFormat.toLowerCase().replace(/\s+/g, '-') + '.md';
const artifactSignals = Array.from(
  new Set(
    [
      lesson.buildIt[0],
      'Capture the key decisions around ' +
        (lesson.concepts[0] ?? lesson.title.toLowerCase()) +
        '.',
      lesson.shipIt[0],
    ].filter((entry): entry is string => Boolean(entry)),
  ),
).slice(0, 3);
const artifactUses = [
  'Reuse it when a teammate needs the fast version of this pattern.',
  'Bring it into the next ' + track.title + ' lesson as your baseline.',
  'Update it after running the next experiment or review loop.',
];
---

<BaseLayout title={lesson.title + ' - AIByDM Learn'} description={lesson.summary}>
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <LearnSectionNav active="roadmap" />

    <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <div
        class="rounded-[32px] border border-[var(--color-border)] bg-[radial-gradient(circle_at_top_left,rgba(56,189,248,0.18),transparent_28%),linear-gradient(180deg,rgba(255,255,255,0.03),transparent),var(--color-bg-surface)] p-6 shadow-[0_24px_90px_rgba(2,8,23,0.28)] sm:p-8 lg:p-10"
      >
        <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--color-text-secondary)]">
          <a href={learnHomeHref} class="transition hover:text-[var(--color-text-primary)]">Learn</a
          >
          <span>/</span>
          <a
            href={getTrackHref(track.slug)}
            class="transition hover:text-[var(--color-text-primary)]">{track.title}</a
          >
          <span>/</span>
          <span class="text-[var(--color-text-primary)]">{lesson.title}</span>
        </div>
        <div class="mt-6 flex flex-wrap gap-2">
          <span
            class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
            >{module.title}</span
          >
          <span
            class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
            >{lesson.format}</span
          >
          <span
            class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
            >{lesson.duration}</span
          >
        </div>
        <h1
          class="mt-6 max-w-4xl text-4xl font-semibold tracking-tight text-[var(--color-text-primary)] sm:text-5xl"
        >
          {lesson.title}
        </h1>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-[var(--color-text-secondary)]">
          {lesson.summary}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <LessonProgressButton client:load trackSlug={track.slug} lessonSlug={lesson.slug} />
          {
            nextLesson && (
              <a
                href={getTrackHref(track.slug) + nextLesson.lesson.slug + '/'}
                class="command-button border border-[var(--color-border)] bg-[var(--color-bg-surface)] text-[var(--color-text-primary)] hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)]"
              >
                Next lesson
                <ArrowRight className="h-4 w-4" aria-hidden="true" />
              </a>
            )
          }
        </div>
      </div>

      <aside class="space-y-6 lg:sticky lg:top-24">
        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <div class="flex items-center gap-3">
            <Compass className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
            <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">Lesson map</h2>
          </div>
          <div class="mt-5 space-y-3">
            <div
              class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4"
            >
              <p
                class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase"
              >
                Challenge
              </p>
              <p class="mt-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                {lesson.challenge}
              </p>
            </div>
            <div
              class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4"
            >
              <div class="flex items-center gap-2">
                <BookMarked className="h-4 w-4 text-[var(--color-learn)]" aria-hidden="true" />
                <p
                  class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase"
                >
                  Concepts
                </p>
              </div>
              <div class="mt-3 flex flex-wrap gap-2">
                {
                  lesson.concepts.map((concept) => (
                    <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-[var(--color-text-secondary)]">
                      {concept}
                    </span>
                  ))
                }
              </div>
            </div>
            <div
              class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4"
            >
              <div class="flex items-center gap-2">
                <Layers3 className="h-4 w-4 text-[var(--color-learn)]" aria-hidden="true" />
                <p
                  class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase"
                >
                  Resources
                </p>
              </div>
              <div class="mt-3 space-y-3">
                {
                  lesson.resources.map((resource) => (
                    <a
                      href={resource.href}
                      target="_blank"
                      rel="noreferrer"
                      class="block rounded-2xl border border-[var(--color-border)] px-4 py-3 text-sm text-[var(--color-text-secondary)] transition hover:border-[var(--color-border-hover)] hover:text-[var(--color-text-primary)]"
                    >
                      <span class="font-medium text-[var(--color-text-primary)]">
                        {resource.label}
                      </span>
                      <span class="mt-1 block text-xs tracking-[0.2em] text-[var(--color-text-tertiary)] uppercase">
                        {resource.kind}
                      </span>
                    </a>
                  ))
                }
              </div>
            </div>
          </div>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <div class="flex items-center gap-3">
            <Sparkles className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
            <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">Track navigation</h2>
          </div>
          <div class="mt-5">
            <LessonRail client:load trackSlug={track.slug} currentLessonSlug={lesson.slug} />
          </div>
        </section>
      </aside>
    </div>

    <div class="mt-8 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <article class="space-y-6">
        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <p
            class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase"
          >
            Lesson thesis
          </p>
          <h2 class="mt-3 text-2xl font-semibold text-[var(--color-text-primary)]">
            {lesson.motto}
          </h2>
          <div class="mt-5 space-y-3">
            {
              lesson.problem.map((paragraph) => (
                <p class="text-sm leading-8 text-[var(--color-text-secondary)] sm:text-base">
                  {paragraph}
                </p>
              ))
            }
          </div>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">
            Learning objectives
          </h2>
          <ul class="mt-5 grid gap-3">
            {
              lesson.objectives.map((objective) => (
                <li class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-4 py-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                  {objective}
                </li>
              ))
            }
          </ul>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">Concept lens</h2>
          <div class="mt-5 grid gap-3">
            {
              lesson.conceptNotes.map((note) => (
                <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-4 py-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                  {note}
                </div>
              ))
            }
          </div>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">Examples</h2>
          <div class="mt-5 space-y-3">
            {
              lesson.examples.map((example) => (
                <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-4 py-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                  {example}
                </div>
              ))
            }
          </div>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">Build it</h2>
          <div class="mt-5 space-y-3">
            {
              lesson.buildIt.map((step) => (
                <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-4 py-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                  {step}
                </div>
              ))
            }
          </div>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">Use it</h2>
          <div class="mt-5 space-y-3">
            {
              lesson.useIt.map((step) => (
                <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-4 py-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                  {step}
                </div>
              ))
            }
          </div>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">Ship it</h2>
          <div class="mt-5 space-y-3">
            {
              lesson.shipIt.map((step) => (
                <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-4 py-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                  {step}
                </div>
              ))
            }
          </div>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <div class="flex items-center gap-3">
            <BookOpen className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
            <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">
              Artifact to keep
            </h2>
          </div>
          <div class="mt-5 grid gap-4 md:grid-cols-[1.05fr_0.95fr]">
            <div
              class="rounded-[24px] border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-5"
            >
              <p
                class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase"
              >
                {artifactFormat}
              </p>
              <h3 class="mt-3 text-xl font-semibold text-[var(--color-text-primary)]">
                {lesson.title} artifact
              </h3>
              <p class="mt-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                Keep one reusable asset that captures the decisions, workflow, and quality checks
                from this lesson so the next build starts faster.
              </p>
              <div class="mt-4 flex flex-wrap gap-2">
                <span
                  class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
                >
                  {artifactFileName}
                </span>
                <span
                  class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
                >
                  {lesson.duration}
                </span>
              </div>
            </div>
            <div class="space-y-3">
              {
                artifactSignals.map((signal) => (
                  <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-4 py-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                    {signal}
                  </div>
                ))
              }
            </div>
          </div>
          <div
            class="mt-5 rounded-[24px] border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-5"
          >
            <p
              class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase"
            >
              Reuse it when
            </p>
            <ul class="mt-4 space-y-2">
              {
                artifactUses.map((item) => (
                  <li class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-surface)] px-4 py-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                    {item}
                  </li>
                ))
              }
            </ul>
          </div>
        </section>

        {
          Content && (
            <section class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]">
              <div class="flex items-center gap-3">
                <BookOpen className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
                <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">
                  Deep dive notes
                </h2>
              </div>
              <div class="prose mt-6 max-w-none">
                <Content />
              </div>
            </section>
          )
        }
      </article>

      <div class="space-y-6">
        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">Key terms</h2>
          <div class="mt-5 space-y-3">
            {
              lesson.keyTerms.map((entry) => (
                <div class="rounded-[24px] border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4">
                  <p class="text-base font-semibold text-[var(--color-text-primary)]">
                    {entry.term}
                  </p>
                  <p class="mt-2 text-sm leading-7 text-[var(--color-text-secondary)]">
                    <span class="font-medium text-[var(--color-text-primary)]">Avoid:</span>{' '}
                    {entry.misconception}
                  </p>
                  <p class="mt-2 text-sm leading-7 text-[var(--color-text-secondary)]">
                    <span class="font-medium text-[var(--color-text-primary)]">
                      Use it like this:
                    </span>{' '}
                    {entry.meaning}
                  </p>
                </div>
              ))
            }
          </div>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">Exercises</h2>
          <div class="mt-5 space-y-3">
            {
              lesson.exercises.map((exercise) => (
                <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-4 py-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                  {exercise}
                </div>
              ))
            }
          </div>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">Related projects</h2>
          <div class="mt-5 space-y-3">
            {
              relatedProjects.map((project) => (
                <a
                  href={getProjectHref(track.slug, project.slug)}
                  class="block rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4 transition hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)]"
                >
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-[var(--color-text-secondary)]">
                      {project.level}
                    </span>
                    <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-[var(--color-text-secondary)]">
                      {project.duration}
                    </span>
                  </div>
                  <p class="mt-3 text-lg font-semibold text-[var(--color-text-primary)]">
                    {project.title}
                  </p>
                  <p class="mt-2 text-sm leading-7 text-[var(--color-text-secondary)]">
                    {project.summary}
                  </p>
                </a>
              ))
            }
          </div>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">Quality bar</h2>
          <div class="mt-5 space-y-3">
            {
              lesson.qualityChecks.map((check) => (
                <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-4 py-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                  {check}
                </div>
              ))
            }
          </div>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <div class="flex items-center gap-3">
            <BookOpen className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
            <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">Lesson output</h2>
          </div>
          <div
            class="mt-5 rounded-[24px] border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-5"
          >
            <div class="flex flex-wrap items-center gap-2">
              <span
                class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
              >
                {lesson.output.kind}
              </span>
              <span
                class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
              >
                Reusable template
              </span>
            </div>
            <h3 class="mt-4 text-xl font-semibold text-[var(--color-text-primary)]">
              {lesson.output.title}
            </h3>
            <p class="mt-3 text-sm leading-7 text-[var(--color-text-secondary)]">
              {lesson.output.summary}
            </p>
            <pre
              class="mt-5 overflow-x-auto rounded-[24px] border border-[var(--color-border)] bg-[rgba(2,6,23,0.72)] p-4 text-sm leading-7 text-[var(--color-text-primary)]"><code>{lesson.output.template}</code></pre>
          </div>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">Interview prompts</h2>
          <div class="mt-5 space-y-3">
            {
              lesson.interviewQuestions.map((question) => (
                <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-4 py-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                  {question}
                </div>
              ))
            }
          </div>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">Next steps</h2>
          <div class="mt-5 space-y-3">
            {
              lesson.nextSteps.map((step) => (
                <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-4 py-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                  {step}
                </div>
              ))
            }
          </div>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">Navigation</h2>
          <div class="mt-5 space-y-3">
            {
              previousLesson ? (
                <a
                  href={getTrackHref(track.slug) + previousLesson.lesson.slug + '/'}
                  class="flex items-center justify-between gap-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4 transition hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)]"
                >
                  <div>
                    <p class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase">
                      Previous
                    </p>
                    <p class="mt-2 text-base font-semibold text-[var(--color-text-primary)]">
                      {previousLesson.lesson.title}
                    </p>
                  </div>
                  <ArrowLeft
                    className="h-4 w-4 text-[var(--color-text-tertiary)]"
                    aria-hidden="true"
                  />
                </a>
              ) : (
                <a
                  href={getTrackHref(track.slug)}
                  class="flex items-center justify-between gap-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4 transition hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)]"
                >
                  <div>
                    <p class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase">
                      Back to track
                    </p>
                    <p class="mt-2 text-base font-semibold text-[var(--color-text-primary)]">
                      {track.title}
                    </p>
                  </div>
                  <ArrowLeft
                    className="h-4 w-4 text-[var(--color-text-tertiary)]"
                    aria-hidden="true"
                  />
                </a>
              )
            }
            {
              nextLesson && (
                <a
                  href={getTrackHref(track.slug) + nextLesson.lesson.slug + '/'}
                  class="flex items-center justify-between gap-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4 transition hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)]"
                >
                  <div>
                    <p class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase">
                      Next
                    </p>
                    <p class="mt-2 text-base font-semibold text-[var(--color-text-primary)]">
                      {nextLesson.lesson.title}
                    </p>
                  </div>
                  <ArrowRight
                    className="h-4 w-4 text-[var(--color-text-tertiary)]"
                    aria-hidden="true"
                  />
                </a>
              )
            }
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
