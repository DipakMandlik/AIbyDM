---
import { ArrowRight, BookOpen, Clock3, Compass, GitBranch, Layers3, Target } from 'lucide-react';

import LearnSectionNav from '@components/learn/LearnSectionNav.astro';
import TrackProgressPanel from '@components/learn/TrackProgressPanel';
import TrackRoadmap from '@components/learn/TrackRoadmap';
import {
  getDependentTracks,
  getLearningTrack,
  getProjectHref,
  getTrackHref,
  getTrackLessonCount,
  getTrackMinutes,
  getTrackProjectCount,
  learningTracks,
  type LearningTrack,
} from '@data/learn/catalog';
import BaseLayout from '@layouts/BaseLayout.astro';

export function getStaticPaths() {
  return learningTracks.map((track) => ({
    params: { track: track.slug },
    props: { track },
  }));
}

interface Props {
  track: LearningTrack;
}

const { track } = Astro.props;
const prerequisiteTracks = track.prerequisites
  .map((slug) => getLearningTrack(slug))
  .filter((entry): entry is LearningTrack => Boolean(entry));
const followOnTracks = getDependentTracks(track.slug);
const learnHomeHref = import.meta.env.BASE_URL + 'learn/';
---

<BaseLayout title={track.title + ' - AIByDM Learn'} description={track.summary}>
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <LearnSectionNav active="roadmap" />

    <div class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
      <div
        class="rounded-[32px] border border-[var(--color-border)] bg-[radial-gradient(circle_at_top_left,rgba(56,189,248,0.18),transparent_28%),linear-gradient(180deg,rgba(255,255,255,0.03),transparent),var(--color-bg-surface)] p-6 shadow-[0_24px_90px_rgba(2,8,23,0.28)] sm:p-8 lg:p-10"
      >
        <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--color-text-secondary)]">
          <a href={learnHomeHref} class="transition hover:text-[var(--color-text-primary)]">Learn</a
          >
          <span>/</span>
          <span class="text-[var(--color-text-primary)]">{track.title}</span>
        </div>
        <p
          class="mt-6 font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase"
        >
          {track.stage} stage
        </p>
        <h1
          class="mt-3 max-w-3xl text-4xl font-semibold tracking-tight text-[var(--color-text-primary)] sm:text-5xl"
        >
          {track.title}
        </h1>
        <p class="mt-4 max-w-3xl text-lg leading-8 text-[var(--color-text-secondary)]">
          {track.strapline}
        </p>
        <p class="mt-5 max-w-3xl text-sm leading-8 text-[var(--color-text-secondary)] sm:text-base">
          {track.summary}
        </p>
        <div class="mt-8 flex flex-wrap gap-2">
          <span
            class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
            >{track.difficulty}</span
          >
          <span
            class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
            >{track.estimatedWeeks}</span
          >
          <span
            class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
            >{getTrackLessonCount(track)} lessons</span
          >
          <span
            class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
            >{getTrackProjectCount(track)} projects</span
          >
          <span
            class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
            >{Math.round(getTrackMinutes(track) / 60)}h estimate</span
          >
        </div>
        <div class="mt-8 grid gap-4 sm:grid-cols-3">
          <div
            class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4"
          >
            <Layers3 className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
            <p class="mt-3 text-sm text-[var(--color-text-secondary)]">Modules</p>
            <p class="mt-2 text-3xl font-semibold text-[var(--color-text-primary)]">
              {track.modules.length}
            </p>
          </div>
          <div
            class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4"
          >
            <Clock3 className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
            <p class="mt-3 text-sm text-[var(--color-text-secondary)]">Rhythm</p>
            <p class="mt-2 text-xl font-semibold text-[var(--color-text-primary)]">
              {track.weeklyRhythm}
            </p>
          </div>
          <div
            class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4"
          >
            <BookOpen className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
            <p class="mt-3 text-sm text-[var(--color-text-secondary)]">Tooling</p>
            <p class="mt-2 text-sm leading-7 text-[var(--color-text-primary)]">
              {track.tooling.join(' / ')}
            </p>
          </div>
        </div>
      </div>

      <TrackProgressPanel client:load trackSlug={track.slug} />
    </div>

    <div class="mt-8 grid gap-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
      <TrackRoadmap client:load trackSlug={track.slug} />

      <div class="space-y-6 lg:sticky lg:top-24">
        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <div class="flex items-center gap-3">
            <Target className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
            <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">
              What you'll be able to do
            </h2>
          </div>
          <ul class="mt-5 space-y-3">
            {
              track.outcomes.map((outcome) => (
                <li class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-4 py-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                  {outcome}
                </li>
              ))
            }
          </ul>
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <div class="flex items-center gap-3">
            <GitBranch className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
            <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">Roadmap links</h2>
          </div>
          {
            prerequisiteTracks.length > 0 && (
              <div class="mt-4">
                <p class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase">
                  Prerequisites
                </p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {prerequisiteTracks.map((entry) => (
                    <a
                      href={getTrackHref(entry.slug)}
                      class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-3 py-1 text-sm text-[var(--color-text-secondary)] transition hover:border-[var(--color-border-hover)] hover:text-[var(--color-text-primary)]"
                    >
                      {entry.title}
                    </a>
                  ))}
                </div>
              </div>
            )
          }
          {
            track.nextTracks.length > 0 && (
              <div class="mt-5">
                <p class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase">
                  Next up
                </p>
                <div class="mt-3 space-y-3">
                  {track.nextTracks.map((slug) => {
                    const nextTrack = getLearningTrack(slug);
                    return nextTrack ? (
                      <a
                        href={getTrackHref(nextTrack.slug)}
                        class="block rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4 transition hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)]"
                      >
                        <p class="text-base font-semibold text-[var(--color-text-primary)]">
                          {nextTrack.title}
                        </p>
                        <p class="mt-2 text-sm leading-7 text-[var(--color-text-secondary)]">
                          {nextTrack.summary}
                        </p>
                      </a>
                    ) : null;
                  })}
                </div>
              </div>
            )
          }
          {
            followOnTracks.length > 0 && (
              <div class="mt-5">
                <p class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase">
                  Unlocks
                </p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {followOnTracks.map((entry) => (
                    <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-[var(--color-text-secondary)]">
                      {entry.title}
                    </span>
                  ))}
                </div>
              </div>
            )
          }
        </section>

        <section
          class="rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
        >
          <div class="flex items-center gap-3">
            <Compass className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
            <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">
              Capstone checkpoint
            </h2>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-[var(--color-text-primary)]">
            {track.capstone.title}
          </h3>
          <p class="mt-3 text-sm leading-7 text-[var(--color-text-secondary)]">
            {track.capstone.summary}
          </p>
          <ul class="mt-4 space-y-2">
            {
              track.capstone.deliverables.map((deliverable) => (
                <li class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-4 py-3 text-sm text-[var(--color-text-secondary)]">
                  {deliverable}
                </li>
              ))
            }
          </ul>
        </section>
      </div>
    </div>

    <section
      class="mt-8 rounded-[28px] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_60px_rgba(2,8,23,0.16)]"
    >
      <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p
            class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase"
          >
            Project ladder
          </p>
          <h2 class="mt-2 text-2xl font-semibold text-[var(--color-text-primary)]">
            Build the track at multiple depths
          </h2>
        </div>
        <p class="max-w-2xl text-sm leading-7 text-[var(--color-text-secondary)]">
          Start with a compact practice sprint, expand into an applied build, pressure-test the
          system design, then ship the capstone.
        </p>
      </div>
      <div class="mt-6 grid gap-4 xl:grid-cols-2">
        {
          track.projects.map((project) => (
            <article
              id={'project-' + project.slug}
              class="rounded-[24px] border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-5"
            >
              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-[var(--color-text-secondary)]">
                  {project.level}
                </span>
                <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-[var(--color-text-secondary)]">
                  {project.duration}
                </span>
                <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-[var(--color-text-secondary)]">
                  {project.difficulty}
                </span>
              </div>
              <h3 class="mt-4 text-2xl font-semibold text-[var(--color-text-primary)]">
                <a
                  href={getProjectHref(track.slug, project.slug)}
                  class="transition hover:text-[var(--color-learn)]"
                >
                  {project.title}
                </a>
              </h3>
              <p class="mt-3 text-sm leading-7 text-[var(--color-text-secondary)]">
                {project.summary}
              </p>
              <a
                href={getProjectHref(track.slug, project.slug)}
                class="mt-5 inline-flex min-h-11 items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-bg-surface)] px-4 text-sm text-[var(--color-text-primary)] transition hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)]"
              >
                Open project brief
                <ArrowRight className="h-4 w-4" aria-hidden="true" />
              </a>
              <div class="mt-5 grid gap-4 md:grid-cols-2">
                <div>
                  <p class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase">
                    Skills learned
                  </p>
                  <div class="mt-3 flex flex-wrap gap-2">
                    {project.skills.map((skill) => (
                      <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-[var(--color-text-secondary)]">
                        {skill}
                      </span>
                    ))}
                  </div>
                </div>
                <div>
                  <p class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase">
                    Technologies
                  </p>
                  <div class="mt-3 flex flex-wrap gap-2">
                    {project.technologies.map((tech) => (
                      <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-[var(--color-text-secondary)]">
                        {tech}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
              <div class="mt-5 grid gap-4 md:grid-cols-2">
                <div>
                  <p class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase">
                    Outcomes
                  </p>
                  <ul class="mt-3 space-y-2">
                    {project.outcomes.map((outcome) => (
                      <li class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-surface)] px-4 py-3 text-sm text-[var(--color-text-secondary)]">
                        {outcome}
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <p class="font-mono text-xs tracking-[0.24em] text-[var(--color-text-tertiary)] uppercase">
                    Deliverables
                  </p>
                  <ul class="mt-3 space-y-2">
                    {project.deliverables.map((deliverable) => (
                      <li class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-surface)] px-4 py-3 text-sm text-[var(--color-text-secondary)]">
                        {deliverable}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </section>
</BaseLayout>
