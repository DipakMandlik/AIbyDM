---
import LearningAtlas from '@components/learn/LearningAtlas';
import LearnSectionNav from '@components/learn/LearnSectionNav.astro';
import BaseLayout from '@layouts/BaseLayout.astro';

const initialQuery = Astro.url.searchParams.get('q') ?? '';
---

<BaseLayout
  title="Resources - AIByDM Learn"
  description="Browse the AIByDM resource library across guides, docs, tools, and papers connected to the curriculum."
>
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <LearnSectionNav active="resources" />
    <LearningAtlas client:load initialView="resources" initialQuery={initialQuery} />
  </section>
</BaseLayout>
