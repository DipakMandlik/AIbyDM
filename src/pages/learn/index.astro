---
import { getCollection } from 'astro:content';
import { BookOpen, Clock, GitPullRequest, Layers } from 'lucide-react';

import BaseLayout from '@layouts/BaseLayout.astro';

const entries = await getCollection('learn', ({ data }) => !data.draft);
const lessons = entries.sort((a, b) => a.data.order - b.data.order);
const tracks = [...new Set(lessons.map((lesson) => lesson.data.track))];
const totalMinutes = lessons.reduce((sum, lesson) => {
  const match = lesson.data.estimatedTime.match(/\d+/);
  return sum + Number(match?.[0] ?? 0);
}, 0);

const lessonRows = lessons.map((lesson) => ({
  entry: lesson,
  anchor: lesson.id.replace(/\.(md|mdx)$/, '').replace(/[\\/]/g, '-'),
}));

const repoIssueUrl = 'https://github.com/DipakMandlik/AIbyDM/issues/new/choose';
---

<BaseLayout
  title="Learn - AIByDM"
  description="Follow AIByDM learning paths for Python, math, and practical AI engineering foundations."
>
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
      <div
        class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 sm:p-8"
      >
        <div
          class="inline-flex min-h-11 items-center gap-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-3 text-sm text-[var(--color-text-secondary)]"
        >
          <BookOpen className="h-4 w-4 text-[var(--color-learn)]" aria-hidden="true" />
          <span class="font-mono">learn/foundations</span>
        </div>
        <h1
          class="mt-6 max-w-2xl text-4xl leading-tight font-semibold text-[var(--color-text-primary)] sm:text-5xl"
        >
          Build the foundation before the framework.
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-8 text-[var(--color-text-secondary)]">
          The Learn hub keeps theory, code, tools, and assessment connected. Start with core Python,
          then lock in the math that explains why models behave the way they do.
        </p>
        <a
          href={repoIssueUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="command-button mt-8 border border-[var(--color-border)] bg-[var(--color-bg-elevated)] text-[var(--color-text-primary)] hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)]"
        >
          <GitPullRequest className="h-5 w-5" aria-hidden="true" />
          Propose a lesson
        </a>
      </div>

      <div class="grid gap-4 sm:grid-cols-3">
        <div
          class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5"
        >
          <Layers className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
          <p class="mt-5 font-mono text-sm text-[var(--color-text-tertiary)]">Tracks</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--color-text-primary)]">
            {tracks.length}
          </p>
        </div>
        <div
          class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5"
        >
          <BookOpen className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
          <p class="mt-5 font-mono text-sm text-[var(--color-text-tertiary)]">Lessons</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--color-text-primary)]">
            {lessons.length}
          </p>
        </div>
        <div
          class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5"
        >
          <Clock className="h-5 w-5 text-[var(--color-learn)]" aria-hidden="true" />
          <p class="mt-5 font-mono text-sm text-[var(--color-text-tertiary)]">Runtime</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--color-text-primary)]">
            {totalMinutes}m
          </p>
        </div>
      </div>
    </div>

    <div class="mt-8 grid gap-4">
      {
        lessonRows.map(({ entry, anchor }, index) => (
          <article
            id={anchor}
            class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5 sm:p-6"
          >
            <div class="grid gap-5 lg:grid-cols-[9rem_1fr_14rem] lg:items-start">
              <div>
                <p class="font-mono text-sm text-[var(--color-learn)]">
                  module {String(index + 1).padStart(2, '0')}
                </p>
                <p class="mt-3 font-mono text-xs text-[var(--color-text-tertiary)]">
                  {entry.data.track} / {entry.data.difficulty}
                </p>
              </div>
              <div>
                <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">
                  {entry.data.title}
                </h2>
                <p class="mt-3 max-w-3xl text-sm leading-7 text-[var(--color-text-secondary)]">
                  {entry.data.description}
                </p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {entry.data.tags.slice(0, 6).map((tag) => (
                    <span class="rounded-md border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-2 py-1 font-mono text-xs text-[var(--color-text-tertiary)]">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4">
                <p class="font-mono text-xs text-[var(--color-text-tertiary)]">Estimated time</p>
                <p class="mt-2 text-xl font-semibold text-[var(--color-text-primary)]">
                  {entry.data.estimatedTime}
                </p>
                <p class="mt-4 font-mono text-xs text-[var(--color-text-tertiary)]">Updated</p>
                <p class="mt-2 text-sm text-[var(--color-text-secondary)]">
                  {entry.data.lastUpdated.toISOString().slice(0, 10)}
                </p>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
