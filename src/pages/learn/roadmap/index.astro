---
import LearnControlCenter from '@components/learn/LearnControlCenter';
import LearningAtlas from '@components/learn/LearningAtlas';
import LearnSectionNav from '@components/learn/LearnSectionNav.astro';
import BaseLayout from '@layouts/BaseLayout.astro';

const initialQuery = Astro.url.searchParams.get('q') ?? '';
---

<BaseLayout
  title="Roadmap - AIByDM Learn"
  description="See the AIByDM learning journey by stage, prerequisite, unlock path, and local progress milestone."
>
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <LearnSectionNav active="roadmap" />
    <LearnControlCenter client:load />
    <LearningAtlas client:load initialView="roadmap" initialQuery={initialQuery} />
  </section>
</BaseLayout>
