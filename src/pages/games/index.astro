---
import { getCollection } from 'astro:content';
import { Clock, Component, Gamepad2, GitPullRequest, Route } from 'lucide-react';

import BaseLayout from '@layouts/BaseLayout.astro';

const entries = await getCollection('games');
const games = entries.sort((a, b) => a.data.name.localeCompare(b.data.name));
const gameTypes = [...new Set(games.map((game) => game.data.type))];
const relatedTopicCount = new Set(games.flatMap((game) => game.data.relatedTopics)).size;
const repoIssueUrl = 'https://github.com/DipakMandlik/AIbyDM/issues/new/choose';
---

<BaseLayout
  title="Games - AIByDM"
  description="Practice AI concepts with AIByDM quiz and flashcard game entries designed for fast recall and interview preparation."
>
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
      <div
        class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 sm:p-8"
      >
        <div
          class="inline-flex min-h-11 items-center gap-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-3 text-sm text-[var(--color-text-secondary)]"
        >
          <Gamepad2 className="h-4 w-4 text-[var(--color-games)]" aria-hidden="true" />
          <span class="font-mono">games/practice-loop</span>
        </div>
        <h1
          class="mt-6 max-w-2xl text-4xl leading-tight font-semibold text-[var(--color-text-primary)] sm:text-5xl"
        >
          Practice that feels closer to a lab run.
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-8 text-[var(--color-text-secondary)]">
          Games are short, focused reinforcement loops. The first entries cover quick quizzes and
          interview flashcards, with metadata ready for future React game components.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-3">
        <div
          class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5"
        >
          <Gamepad2 className="h-5 w-5 text-[var(--color-games)]" aria-hidden="true" />
          <p class="mt-5 font-mono text-sm text-[var(--color-text-tertiary)]">Games</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--color-text-primary)]">{games.length}</p>
        </div>
        <div
          class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5"
        >
          <Component className="h-5 w-5 text-[var(--color-games)]" aria-hidden="true" />
          <p class="mt-5 font-mono text-sm text-[var(--color-text-tertiary)]">Types</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--color-text-primary)]">
            {gameTypes.length}
          </p>
        </div>
        <div
          class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5"
        >
          <Route className="h-5 w-5 text-[var(--color-games)]" aria-hidden="true" />
          <p class="mt-5 font-mono text-sm text-[var(--color-text-tertiary)]">Topics</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--color-text-primary)]">
            {relatedTopicCount}
          </p>
        </div>
      </div>
    </div>

    <div class="mt-8 grid gap-4 lg:grid-cols-2">
      {
        games.map((game, index) => (
          <article class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5 sm:p-6">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <p class="font-mono text-sm text-[var(--color-games)]">
                  practice {String(index + 1).padStart(2, '0')}
                </p>
                <h2 class="mt-2 text-2xl font-semibold text-[var(--color-text-primary)]">
                  {game.data.name}
                </h2>
              </div>
              <span class="rounded-md border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-2 py-1 font-mono text-xs text-[var(--color-text-tertiary)]">
                {game.data.type}
              </span>
            </div>
            <p class="mt-4 text-sm leading-7 text-[var(--color-text-secondary)]">
              {game.data.description}
            </p>

            <div class="mt-5 grid gap-3 sm:grid-cols-2">
              <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4">
                <Clock className="h-4 w-4 text-[var(--color-games)]" aria-hidden="true" />
                <p class="mt-3 font-mono text-xs text-[var(--color-text-tertiary)]">
                  Estimated run
                </p>
                <p class="mt-1 text-lg font-semibold text-[var(--color-text-primary)]">
                  {game.data.estimatedTime}
                </p>
              </div>
              <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4">
                <Component className="h-4 w-4 text-[var(--color-games)]" aria-hidden="true" />
                <p class="mt-3 font-mono text-xs text-[var(--color-text-tertiary)]">Component</p>
                <p class="mt-1 font-mono text-sm break-words text-[var(--color-text-primary)]">
                  {game.data.component}
                </p>
              </div>
            </div>

            <div class="mt-5 flex flex-wrap gap-2">
              {game.data.relatedTopics.map((topic) => (
                <span class="rounded-md border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-2 py-1 font-mono text-xs text-[var(--color-text-tertiary)]">
                  {topic}
                </span>
              ))}
            </div>
          </article>
        ))
      }
    </div>

    <div
      class="mt-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5 sm:flex sm:items-center sm:justify-between sm:gap-6"
    >
      <div>
        <p class="font-mono text-sm text-[var(--color-games)]">next game lane</p>
        <p class="mt-2 text-sm leading-7 text-[var(--color-text-secondary)]">
          Good game submissions should map to a lesson, fit inside a short session, and expose clear
          scoring or recall feedback.
        </p>
      </div>
      <a
        href={repoIssueUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="command-button mt-4 border border-[var(--color-border)] bg-[var(--color-bg-elevated)] text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)] sm:mt-0"
      >
        <GitPullRequest className="h-5 w-5" aria-hidden="true" />
        Propose game
      </a>
    </div>
  </section>
</BaseLayout>
