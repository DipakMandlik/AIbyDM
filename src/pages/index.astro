---
import { getCollection } from 'astro:content';

import ProductHome from '@components/interactive/ProductHome';
import {
  getTrackLessonCount,
  getTrackProjectCount,
  learningStageGroups,
  learnTotals,
  type LearningTrack,
} from '@data/learn/catalog';
import BaseLayout from '@layouts/BaseLayout.astro';

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, '')}`;

const [toolEntries, examEntries, gameEntries, newsletterEntries] = await Promise.all([
  getCollection('tools'),
  getCollection('exams'),
  getCollection('games'),
  getCollection('newsletter'),
]);

const questionCount = examEntries.reduce((total, exam) => total + exam.data.questions.length, 0);
const indexedLearningEntries = learnTotals.tracks + learnTotals.lessons + learnTotals.projects;
const repoUrl = 'https://github.com/DipakMandlik/AIByDM';

function toTrackPreview(track: LearningTrack) {
  return {
    slug: track.slug,
    title: track.title,
    strapline: track.strapline,
    difficulty: track.difficulty,
    estimatedWeeks: track.estimatedWeeks,
    lessons: getTrackLessonCount(track),
    projects: getTrackProjectCount(track),
  };
}

const stages = learningStageGroups.map((group) => ({
  stage: group.stage,
  eyebrow: group.eyebrow,
  title: group.title,
  summary: group.summary,
  tracks: group.tracks.map(toTrackPreview),
}));

const metrics = [
  {
    label: 'Tracks',
    value: String(learnTotals.tracks),
    detail: 'Connected paths from foundations to enterprise AI.',
  },
  {
    label: 'Lessons',
    value: String(learnTotals.lessons),
    detail: 'Short, structured lesson briefs with next steps.',
  },
  {
    label: 'Projects',
    value: String(learnTotals.projects),
    detail: 'Practice ladders from starter sprint to capstone.',
  },
  {
    label: 'Practice',
    value: String(questionCount + gameEntries.length),
    detail: 'Assessment prompts and reinforcement loops.',
  },
];

const modules = [
  {
    title: 'Learn',
    href: withBase('/learn/'),
    metric: `${learnTotals.tracks} tracks`,
    description: 'Structured learning paths, local progress, project ladders, and roadmap unlocks.',
    accent: 'var(--color-learn)',
    eyebrow: 'Start',
    cta: 'Open learn platform',
  },
  {
    title: 'Tools',
    href: withBase('/tools/'),
    metric: `${toolEntries.length} guides`,
    description:
      'Practical tooling context for local LLMs, frameworks, vector search, and delivery workflows.',
    accent: 'var(--color-tools)',
    eyebrow: 'Build',
    cta: 'Browse tool stack',
  },
  {
    title: 'Games',
    href: withBase('/games/'),
    metric: `${gameEntries.length} loops`,
    description: 'Fast reinforcement layers for recall, fluency, and interview rhythm.',
    accent: 'var(--color-games)',
    eyebrow: 'Practice',
    cta: 'Open game lab',
  },
  {
    title: 'Exams',
    href: withBase('/exams/'),
    metric: `${questionCount} prompts`,
    description:
      'Question banks with explanations and topic coverage to validate what is sticking.',
    accent: 'var(--color-exams)',
    eyebrow: 'Assess',
    cta: 'Review assessments',
  },
  {
    title: 'Newsletter',
    href: withBase('/newsletter/'),
    metric: `${newsletterEntries.length} issues`,
    description:
      'Release signal for what shipped, what changed, and what the learning system is building next.',
    accent: 'var(--color-newsletter)',
    eyebrow: 'Signal',
    cta: 'Read release signal',
  },
  {
    title: 'Community',
    href: withBase('/community/'),
    metric: 'Contributor hub',
    description:
      'Clear contribution lanes, discussion spaces, roadmap visibility, and community operating rhythm.',
    accent: 'var(--color-community)',
    eyebrow: 'Collaborate',
    cta: 'Enter community hub',
  },
  {
    title: 'Search',
    href: withBase('/search/'),
    metric: `${indexedLearningEntries} entries`,
    description:
      'Search tracks, lessons, modules, and projects without losing your place in the roadmap.',
    accent: 'var(--color-learn)',
    eyebrow: 'Find',
    cta: 'Search the curriculum',
  },
];
---

<BaseLayout
  title="AIByDM - Learn AI. Build AI. Master AI."
  description="AIByDM is an open-source AI learning platform built as a guided product journey across structured tracks, projects, tools, practice, and community collaboration."
>
  <ProductHome
    client:load
    repoUrl={repoUrl}
    discussionUrl={`${repoUrl}/discussions`}
    communityHref={withBase('/community/')}
    roadmapHref={withBase('/learn/roadmap/')}
    searchHref={withBase('/search/')}
    learnHref={withBase('/learn/')}
    modules={modules}
    metrics={metrics}
    stages={stages}
  />
</BaseLayout>
