---
import { getCollection } from 'astro:content';

import HomepageLanding from '@components/marketing/HomepageLanding.astro';
import {
  getLearningTrack,
  getTrackHref,
  getTrackLessonCount,
  learnTotals,
} from '@data/learn/catalog';
import BaseLayout from '@layouts/BaseLayout.astro';

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, '')}`;

const [toolEntries, examEntries, gameEntries, newsletterEntries] = await Promise.all([
  getCollection('tools'),
  getCollection('exams'),
  getCollection('games'),
  getCollection('newsletter'),
]);

const questionCount = examEntries.reduce((total, exam) => total + exam.data.questions.length, 0);
const repoUrl = 'https://github.com/DipakMandlik/AIByDM';

type FeatureCard = {
  kind: 'learn' | 'tools' | 'games' | 'exams' | 'newsletter';
  title: string;
  href: string;
  metric: string;
  description: string;
  accent: string;
};

type LearningPathCard = {
  title: string;
  href: string;
  subtitle: string;
  lessonsLabel: string;
  progress: number;
  accent: string;
};

type NewsletterHighlight = {
  title: string;
  href: string;
  meta: string;
};

type StatCard = {
  kind: 'tracks' | 'tools' | 'projects' | 'games' | 'questions' | 'lessons';
  value: string;
  label: string;
  accent: string;
};
const featureCards: FeatureCard[] = [
  {
    kind: 'learn',
    title: 'Learn',
    href: withBase('/learn/'),
    metric: `${learnTotals.tracks}+ tracks`,
    description: 'Structured courses, projects, and roadmap-driven learning paths.',
    accent: 'var(--color-learn)',
  },
  {
    kind: 'tools',
    title: 'Tools',
    href: withBase('/tools/'),
    metric: `${toolEntries.length}+ guides`,
    description: 'Discover practical open-source AI tools and workflow companions.',
    accent: 'var(--color-tools)',
  },
  {
    kind: 'games',
    title: 'Games',
    href: withBase('/games/'),
    metric: `${gameEntries.length}+ games`,
    description: 'Play and practice with interactive loops designed for retention.',
    accent: 'var(--color-games)',
  },
  {
    kind: 'exams',
    title: 'Exams',
    href: withBase('/exams/'),
    metric: `${questionCount}+ questions`,
    description: 'Prepare with exams, MCQs, and quick checks to validate understanding.',
    accent: 'var(--color-exams)',
  },
  {
    kind: 'newsletter',
    title: 'Newsletter',
    href: withBase('/newsletter/'),
    metric: `${newsletterEntries.length}+ issues`,
    description: 'Stay updated with weekly learning highlights, releases, and community signal.',
    accent: 'var(--color-newsletter)',
  },
];

const aiFoundationsTrack = getLearningTrack('ai-foundations');
const llmEngineeringTrack = getLearningTrack('llm-engineering');
const aiGovernanceTrack = getLearningTrack('ai-governance');
const machineLearningTrack = getLearningTrack('machine-learning');

if (!aiFoundationsTrack || !llmEngineeringTrack || !aiGovernanceTrack || !machineLearningTrack) {
  throw new Error('Expected showcase learning tracks are missing from the catalog.');
}

const learningPaths: LearningPathCard[] = [
  {
    title: 'AI Engineer Path',
    href: getTrackHref(aiFoundationsTrack.slug),
    subtitle: 'Beginner to Advanced',
    lessonsLabel: `${getTrackLessonCount(aiFoundationsTrack)} lessons`,
    progress: 68,
    accent: '#6d5dfd',
  },
  {
    title: 'LLM Engineer Path',
    href: getTrackHref(llmEngineeringTrack.slug),
    subtitle: 'Build LLMs and Agents',
    lessonsLabel: `${getTrackLessonCount(llmEngineeringTrack)} lessons`,
    progress: 55,
    accent: '#60a5fa',
  },
  {
    title: 'AI Governance Path',
    href: getTrackHref(aiGovernanceTrack.slug),
    subtitle: 'Responsible AI and Ethics',
    lessonsLabel: `${getTrackLessonCount(aiGovernanceTrack)} lessons`,
    progress: 40,
    accent: '#f59e0b',
  },
  {
    title: 'Data Scientist Path',
    href: getTrackHref(machineLearningTrack.slug),
    subtitle: 'ML, Data, and Evaluation',
    lessonsLabel: `${getTrackLessonCount(machineLearningTrack)} lessons`,
    progress: 72,
    accent: '#14b8a6',
  },
];

const latestNewsletterEntry = newsletterEntries
  .slice()
  .sort((left, right) => right.data.date.getTime() - left.data.date.getTime())[0];

const newsletterHighlights: NewsletterHighlight[] = [
  {
    title: latestNewsletterEntry?.data.title ?? 'AIByDM Launch Issue',
    href: withBase('/newsletter/'),
    meta: latestNewsletterEntry
      ? latestNewsletterEntry.data.date.toLocaleDateString('en-US', {
          month: 'long',
          day: 'numeric',
          year: 'numeric',
        })
      : 'June 1, 2026',
  },
  {
    title: 'Public roadmap is live',
    href: withBase('/learn/roadmap/'),
    meta: 'Track the next platform milestones',
  },
  {
    title: 'Community hub is ready',
    href: withBase('/community/'),
    meta: 'Discussions, support, and contribution flow',
  },
];

const stats: StatCard[] = [
  {
    kind: 'tracks',
    value: `${learnTotals.tracks}+`,
    label: 'Learning tracks',
    accent: '#6d5dfd',
  },
  {
    kind: 'tools',
    value: `${toolEntries.length}+`,
    label: 'Open-source tools',
    accent: '#3b82f6',
  },
  {
    kind: 'projects',
    value: `${learnTotals.projects}+`,
    label: 'Hands-on projects',
    accent: '#14b8a6',
  },
  {
    kind: 'games',
    value: `${gameEntries.length}+`,
    label: 'Practice games',
    accent: '#f472b6',
  },
  {
    kind: 'questions',
    value: `${questionCount}+`,
    label: 'Exam questions',
    accent: '#f59e0b',
  },
  {
    kind: 'lessons',
    value: `${learnTotals.lessons}+`,
    label: 'Guided lessons',
    accent: '#8b5cf6',
  },
];
---

<BaseLayout
  title="AIByDM - Learn AI. Build AI. Master AI."
  description="AIByDM is an open-source AI learning platform built as a guided product journey across structured tracks, projects, tools, practice, and community collaboration."
  showHeader={false}
  showFooter={false}
  bodyClass="homepage-body"
>
  <HomepageLanding
    repoUrl={repoUrl}
    communityHref={withBase('/community/')}
    roadmapHref={withBase('/learn/roadmap/')}
    searchHref={withBase('/search/')}
    learnHref={withBase('/learn/')}
    toolsHref={withBase('/tools/')}
    gamesHref={withBase('/games/')}
    examsHref={withBase('/exams/')}
    newsletterHref={withBase('/newsletter/')}
    featureCards={featureCards}
    learningPaths={learningPaths}
    newsletterHighlights={newsletterHighlights}
    stats={stats}
  />
</BaseLayout>
