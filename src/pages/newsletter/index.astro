---
import { getCollection } from 'astro:content';
import { CalendarDays, GitPullRequest, Mail, Newspaper, Radio } from 'lucide-react';

import BaseLayout from '@layouts/BaseLayout.astro';

const entries = await getCollection('newsletter');
const issues = entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestIssue = issues[0];
const categories = [...new Set(issues.flatMap((issue) => issue.data.categories))];
const dateFormatter = new Intl.DateTimeFormat('en', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
const discussionsUrl = 'https://github.com/DipakMandlik/AIByDM/discussions';
---

<BaseLayout
  title="Newsletter - AIByDM"
  description="Read AIByDM newsletter issues with release notes, learning updates, and practical AI engineering direction."
>
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="grid gap-6 lg:grid-cols-[1fr_0.85fr]">
      <div
        class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 sm:p-8"
      >
        <div
          class="inline-flex min-h-11 items-center gap-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-3 text-sm text-[var(--color-text-secondary)]"
        >
          <Newspaper className="h-4 w-4 text-[var(--color-newsletter)]" aria-hidden="true" />
          <span class="font-mono">newsletter/signal</span>
        </div>
        <h1
          class="mt-6 max-w-3xl text-4xl leading-tight font-semibold text-[var(--color-text-primary)] sm:text-5xl"
        >
          Release signal for the learning system.
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-8 text-[var(--color-text-secondary)]">
          Newsletter entries track what shipped, what changed, and what the project is building
          next. It is the editorial layer for learners and contributors.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
        <div
          class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5"
        >
          <Mail className="h-5 w-5 text-[var(--color-newsletter)]" aria-hidden="true" />
          <p class="mt-4 font-mono text-sm text-[var(--color-text-tertiary)]">Issues</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--color-text-primary)]">
            {issues.length}
          </p>
        </div>
        <div
          class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5"
        >
          <Radio className="h-5 w-5 text-[var(--color-newsletter)]" aria-hidden="true" />
          <p class="mt-4 font-mono text-sm text-[var(--color-text-tertiary)]">Categories</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--color-text-primary)]">
            {categories.length}
          </p>
        </div>
        <div
          class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5"
        >
          <CalendarDays className="h-5 w-5 text-[var(--color-newsletter)]" aria-hidden="true" />
          <p class="mt-4 font-mono text-sm text-[var(--color-text-tertiary)]">Latest</p>
          <p class="mt-2 text-lg font-semibold text-[var(--color-text-primary)]">
            {latestIssue ? dateFormatter.format(latestIssue.data.date) : 'Queued'}
          </p>
        </div>
      </div>
    </div>

    <div class="mt-8 grid gap-4">
      {
        issues.map((issue) => (
          <article class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5 sm:p-6">
            <div class="grid gap-6 lg:grid-cols-[10rem_1fr_14rem]">
              <div>
                <p class="font-mono text-sm text-[var(--color-newsletter)]">
                  Issue {issue.data.issueNumber}
                </p>
                <p class="mt-3 font-mono text-xs text-[var(--color-text-tertiary)]">
                  {dateFormatter.format(issue.data.date)}
                </p>
              </div>
              <div>
                <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">
                  {issue.data.title}
                </h2>
                <p class="mt-3 max-w-3xl text-sm leading-7 text-[var(--color-text-secondary)]">
                  {issue.data.description}
                </p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {issue.data.categories.map((category) => (
                    <span class="rounded-md border border-[var(--color-border)] bg-[var(--color-bg-panel)] px-2 py-1 font-mono text-xs text-[var(--color-text-tertiary)]">
                      {category}
                    </span>
                  ))}
                </div>
              </div>
              <aside class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-panel)] p-4">
                <p class="font-mono text-xs text-[var(--color-text-tertiary)]">Author</p>
                <p class="mt-2 text-sm font-semibold text-[var(--color-text-primary)]">
                  {issue.data.author}
                </p>
                <p class="mt-5 font-mono text-xs text-[var(--color-text-tertiary)]">Featured</p>
                <p class="mt-2 text-sm text-[var(--color-text-secondary)]">
                  {issue.data.featured ? 'Yes' : 'No'}
                </p>
              </aside>
            </div>
          </article>
        ))
      }
    </div>

    <div
      class="mt-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-5 sm:flex sm:items-center sm:justify-between sm:gap-6"
    >
      <div>
        <p class="font-mono text-sm text-[var(--color-newsletter)]">community signal</p>
        <p class="mt-2 text-sm leading-7 text-[var(--color-text-secondary)]">
          Use discussions for launch notes, content requests, collaboration ideas, and release
          feedback.
        </p>
      </div>
      <a
        href={discussionsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="command-button mt-4 border border-[var(--color-border)] bg-[var(--color-bg-elevated)] text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)] sm:mt-0"
      >
        <GitPullRequest className="h-5 w-5" aria-hidden="true" />
        Open discussions
      </a>
    </div>
  </section>
</BaseLayout>
