---
import '@styles/global.css';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, '')}`;
const siteBaseURL = new URL(import.meta.env.BASE_URL, Astro.site);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = ogImage
  ? new URL(withBase(ogImage), Astro.site).href
  : new URL(withBase('/og-default.png'), Astro.site).href;

const isHomepage =
  Astro.url.pathname === import.meta.env.BASE_URL ||
  Astro.url.pathname === '/' ||
  Astro.url.pathname === '';
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="icon" href={withBase('/favicon.ico')} sizes="32x32" />
    <link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="sitemap" href={withBase('/sitemap-index.xml')} />

    <!-- Open Graph -->
    <meta property="og:type" content={isHomepage ? 'website' : 'article'} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:site_name" content="AIByDM" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />

    <!-- JSON-LD: WebSite schema on homepage -->
    {
      isHomepage && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify({
            '@context': 'https://schema.org',
            '@type': 'WebSite',
            name: 'AIByDM',
            url: siteBaseURL.href,
            description:
              'Learn AI. Build AI. Master AI. A free, open-source learning platform for artificial intelligence.',
            potentialAction: {
              '@type': 'SearchAction',
              target: {
                '@type': 'EntryPoint',
                urlTemplate: `${siteBaseURL.href}search/?q={search_term_string}`,
              },
              'query-input': 'required name=search_term_string',
            },
          })}
        />
      )
    }

    <!-- Theme initialization (runs before paint to prevent flash) -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('aibydm-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

        if (stored === 'light' || (!stored && !prefersDark)) {
          document.documentElement.classList.remove('dark');
          document.documentElement.classList.add('light');
        } else {
          document.documentElement.classList.remove('light');
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body
    class="flex min-h-screen flex-col bg-[var(--color-bg-base)] text-[var(--color-text-primary)] antialiased"
  >
    <a
      href="#main-content"
      class="skip-to-content focus:ring-2 focus:ring-[var(--color-accent)] focus:outline-none"
    >
      Skip to content
    </a>

    <Header />

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
