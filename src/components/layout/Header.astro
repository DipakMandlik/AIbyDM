---
import ThemeToggle from '@components/interactive/ThemeToggle';

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, '')}`;

const navLinks = [
  { label: 'Learn', href: withBase('/learn/') },
  { label: 'Tools', href: withBase('/tools/') },
  { label: 'Games', href: withBase('/games/') },
  { label: 'Exams', href: withBase('/exams/') },
  { label: 'Newsletter', href: withBase('/newsletter/') },
];

const currentPath = Astro.url.pathname;
const homeHref = withBase('/');
const isActive = (href: string) =>
  currentPath === href || (href !== homeHref && currentPath.startsWith(href));
---

<header class="app-topbar" id="site-header">
  <button
    id="sidebar-toggle"
    class="sidebar-toggle"
    type="button"
    aria-label="Toggle sidebar navigation"
    aria-expanded="false"
    aria-controls="app-sidebar"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>

  <nav class="topbar-nav" aria-label="Primary navigation">
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class:list={['topbar-link', isActive(link.href) && 'is-active']}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))
    }
  </nav>

  <div class="topbar-actions">
    <button
      class="topbar-search"
      type="button"
      data-command-open
      aria-label="Search AIByDM (Command or Control + K)"
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
      <span>Search AIByDM...</span>
      <kbd>⌘K</kbd>
    </button>

    <ThemeToggle client:load />

    <button class="bell" type="button" aria-label="Notifications (3 unread)">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"></path>
        <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"></path>
      </svg>
      <span class="bell-badge" aria-hidden="true">3</span>
    </button>

    <a class="join-button" href="https://github.com/DipakMandlik/AIbyDM/discussions">
      Join Community
    </a>

    <a
      class="avatar"
      href="https://github.com/DipakMandlik/AIbyDM"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Account"
    >
      <span>DM</span>
    </a>
  </div>
</header>

<script is:inline>
  (function () {
    const header = document.getElementById('site-header');
    const toggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('app-sidebar');
    const scrim = document.getElementById('sidebar-scrim');

    function updateHeader() {
      if (!header) return;
      header.dataset.scrolled = String(window.scrollY > 8);
    }

    updateHeader();
    window.addEventListener('scroll', updateHeader, { passive: true });

    function closeSidebar() {
      sidebar?.classList.remove('is-open');
      if (scrim) scrim.hidden = true;
      toggle?.setAttribute('aria-expanded', 'false');
    }

    if (toggle && sidebar) {
      toggle.addEventListener('click', function () {
        const isOpen = sidebar.classList.toggle('is-open');
        if (scrim) scrim.hidden = !isOpen;
        toggle.setAttribute('aria-expanded', String(isOpen));
      });
    }

    scrim?.addEventListener('click', closeSidebar);
    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') closeSidebar();
    });
  })();
</script>
