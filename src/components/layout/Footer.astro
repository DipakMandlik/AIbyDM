---
import { ArrowRight, ExternalLink } from 'lucide-react';

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, '')}`;
const repoUrl = 'https://github.com/DipakMandlik/AIByDM';

const footerSections = [
  {
    title: 'Platform',
    links: [
      { label: 'Learn', href: '/learn/', external: false },
      { label: 'Roadmap', href: '/learn/roadmap/', external: false },
      { label: 'Search', href: '/search/', external: false },
      { label: 'Community', href: '/community/', external: false },
    ],
  },
  {
    title: 'Practice',
    links: [
      { label: 'Tools', href: '/tools/', external: false },
      { label: 'Games', href: '/games/', external: false },
      { label: 'Exams', href: '/exams/', external: false },
      { label: 'Newsletter', href: '/newsletter/', external: false },
    ],
  },
  {
    title: 'Open Source',
    links: [
      { label: 'Contributing', href: `${repoUrl}/blob/main/CONTRIBUTING.md`, external: true },
      { label: 'Roadmap.md', href: `${repoUrl}/blob/main/ROADMAP.md`, external: true },
      { label: 'Community.md', href: `${repoUrl}/blob/main/COMMUNITY.md`, external: true },
      { label: 'Discussions', href: `${repoUrl}/discussions`, external: true },
    ],
  },
  {
    title: 'Trust',
    links: [
      { label: 'License', href: `${repoUrl}/blob/main/LICENSE`, external: true },
      { label: 'Code of Conduct', href: `${repoUrl}/blob/main/CODE_OF_CONDUCT.md`, external: true },
      { label: 'Security', href: `${repoUrl}/blob/main/SECURITY.md`, external: true },
      { label: 'Support', href: `${repoUrl}/blob/main/SUPPORT.md`, external: true },
    ],
  },
];

const currentYear = new Date().getFullYear();
---

<footer
  class="mt-auto border-t border-[var(--color-border)] bg-[var(--color-bg-surface)]"
  role="contentinfo"
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div
      class="rounded-[30px] border border-[var(--color-border)] bg-[radial-gradient(circle_at_top_left,rgba(56,189,248,0.12),transparent_22rem),linear-gradient(180deg,rgba(255,255,255,0.03),transparent),var(--color-bg-panel)] p-6 shadow-[0_18px_50px_rgba(2,8,23,0.14)] sm:p-8"
    >
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <p class="text-xs tracking-[0.22em] text-[var(--color-text-tertiary)] uppercase">
            AIByDM
          </p>
          <h2 class="mt-2 text-3xl font-semibold text-[var(--color-text-primary)] sm:text-4xl">
            Learn AI like a product team, not a bookmark folder.
          </h2>
          <p class="mt-4 text-sm leading-8 text-[var(--color-text-secondary)] sm:text-base">
            Follow structured tracks, keep your place with local progress, reinforce what you learn,
            and help improve the platform in public.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a
            href={withBase('/learn/')}
            class="command-button border border-transparent bg-[var(--color-accent)] text-[var(--color-accent-contrast)] hover:bg-[var(--color-accent-hover)]"
          >
            Start learning
            <ArrowRight className="h-4 w-4" aria-hidden="true" />
          </a>
          <a
            href={withBase('/community/')}
            class="command-button border border-[var(--color-border)] bg-[var(--color-bg-surface)] text-[var(--color-text-primary)] hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)]"
          >
            Community hub
          </a>
        </div>
      </div>
    </div>

    <div class="mt-10 grid grid-cols-2 gap-8 sm:grid-cols-4">
      {
        footerSections.map((section) => (
          <div>
            <h2 class="mb-3 text-sm font-semibold text-[var(--color-text-primary)]">
              {section.title}
            </h2>
            <ul class="space-y-2" role="list">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.external ? link.href : withBase(link.href)}
                    class="inline-flex min-h-8 items-center gap-1 text-sm text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)]"
                    target={link.external ? '_blank' : undefined}
                    rel={link.external ? 'noopener noreferrer' : undefined}
                  >
                    {link.label}
                    {link.external && (
                      <ExternalLink className="h-3 w-3 opacity-60" aria-hidden="true" />
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-10 flex flex-col items-center justify-between gap-3 border-t border-[var(--color-border)] pt-8 sm:flex-row"
    >
      <p class="text-sm text-[var(--color-text-secondary)]">
        <span class="font-semibold text-[var(--color-text-primary)]">AIByDM</span>
        {' '}Learn AI. Build AI. Master AI.
      </p>
      <p class="text-sm text-[var(--color-text-tertiary)]">
        &copy; {currentYear} AIByDM. Open source under MIT License.
      </p>
    </div>
  </div>
</footer>
