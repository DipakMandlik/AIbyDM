---
const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, '')}`;

const repo = 'https://github.com/DipakMandlik/AIbyDM';

const columns = [
  {
    title: 'Product',
    links: [
      ['Learn', '/learn/'],
      ['Tools directory', '/tools/'],
      ['Games zone', '/games/'],
      ['Interview hub', '/exams/'],
      ['Newsletter', '/newsletter/'],
    ],
  },
  {
    title: 'Resources',
    links: [
      ['Roadmap', '/learn/'],
      ['Contributing', `${repo}/blob/main/CONTRIBUTING.md`],
      ['Changelog', `${repo}/releases`],
      ['Support', `${repo}/blob/main/SUPPORT.md`],
      ['Security', `${repo}/blob/main/SECURITY.md`],
    ],
  },
  {
    title: 'Open Source',
    links: [
      ['GitHub', repo],
      ['Discussions', `${repo}/discussions`],
      ['Issues', `${repo}/issues`],
      ['Sponsors', 'https://github.com/sponsors/DipakMandlik'],
      ['License', `${repo}/blob/main/LICENSE`],
    ],
  },
  {
    title: 'Community',
    links: [
      ['Contributors', `${repo}/graphs/contributors`],
      ['Submit a tool', '/tools/'],
      ['Code of conduct', `${repo}/blob/main/CODE_OF_CONDUCT.md`],
      ['Governance', `${repo}/blob/main/GOVERNANCE.md`],
      ['Maintainers', `${repo}/blob/main/MAINTAINERS.md`],
    ],
  },
];

const currentYear = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-shell">
    <section class="footer-cta" aria-label="Newsletter signup">
      <div>
        <span>AIByDM Weekly</span>
        <h2>Ship smarter AI systems every week.</h2>
        <p>
          Curated model releases, open-source tools, interview prep, and production lessons for AI
          builders.
        </p>
      </div>
      <form class="footer-form" data-newsletter-form>
        <label class="sr-only" for="footer-email">Email address</label>
        <input id="footer-email" type="email" placeholder="you@example.com" />
        <button type="submit">Subscribe</button>
      </form>
    </section>

    <div class="footer-main">
      <div class="footer-brand">
        <a href={withBase('/')} class="brand-mark" aria-label="AIByDM home">
          <span>AI</span>
          <strong>AIByDM</strong>
        </a>
        <p>
          A premium open-source AI engineering platform for learning, tools, games, interview prep,
          and community contribution.
        </p>
      </div>

      {
        columns.map((column) => (
          <nav aria-label={column.title}>
            <h3>{column.title}</h3>
            {column.links.map(([label, href]) => {
              const external = href.startsWith('https://');
              return (
                <a
                  href={external ? href : withBase(href)}
                  target={external ? '_blank' : undefined}
                  rel={external ? 'noopener noreferrer' : undefined}
                >
                  {label}
                </a>
              );
            })}
          </nav>
        ))
      }
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} AIByDM. Open source under MIT License.</p>
      <div>
        <a href={`${repo}/blob/main/LICENSE`} target="_blank" rel="noopener noreferrer">License</a>
        <a href={`${repo}/blob/main/SECURITY.md`} target="_blank" rel="noopener noreferrer"
          >Security</a
        >
        <a href={repo} target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  document.querySelectorAll('[data-newsletter-form]').forEach((form) => {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const button = form.querySelector('button');
      if (button) button.textContent = 'Joined';
    });
  });
</script>
