---
const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, '')}`;
const footerSections = [
  {
    title: 'Platform',
    links: [
      { label: 'Learn', href: withBase('/learn/') },
      { label: 'Tools', href: withBase('/tools/') },
      { label: 'Games', href: withBase('/games/') },
      { label: 'Exams', href: withBase('/exams/') },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Newsletter', href: withBase('/newsletter/') },
      { label: 'Contributing', href: withBase('/contributing/') },
      { label: 'Roadmap', href: withBase('/roadmap/') },
    ],
  },
  {
    title: 'Community',
    links: [
      {
        label: 'GitHub',
        href: 'https://github.com/DipakMandlik/AIbyDM',
        external: true,
      },
      {
        label: 'Discussions',
        href: 'https://github.com/DipakMandlik/AIbyDM/discussions',
        external: true,
      },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'License', href: withBase('/license/') },
      { label: 'Code of Conduct', href: withBase('/code-of-conduct/') },
    ],
  },
];

const currentYear = new Date().getFullYear();
---

<footer
  class="mt-auto border-t border-[var(--color-border)] bg-[var(--color-bg-surface)]"
  role="contentinfo"
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Link columns -->
    <div class="grid grid-cols-2 gap-8 sm:grid-cols-4">
      {
        footerSections.map((section) => (
          <div>
            <h3 class="mb-3 text-sm font-semibold tracking-wide text-[var(--color-text-primary)]">
              {section.title}
            </h3>
            <ul class="space-y-2" role="list">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="inline-flex items-center gap-1 text-sm text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)]"
                    {...('external' in link && link.external
                      ? {
                          target: '_blank',
                          rel: 'noopener noreferrer',
                        }
                      : {})}
                  >
                    {link.label}
                    {'external' in link && link.external && (
                      <svg
                        width="12"
                        height="12"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="opacity-50"
                        aria-hidden="true"
                      >
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                        <polyline points="15 3 21 3 21 9" />
                        <line x1="10" x2="21" y1="14" y2="3" />
                      </svg>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-10 flex flex-col items-center justify-between gap-3 border-t border-[var(--color-border)] pt-8 sm:flex-row"
    >
      <p class="text-sm text-[var(--color-text-secondary)]">
        <span class="font-semibold text-[var(--color-text-primary)]">AIByDM</span>
        &mdash; Learn AI. Build AI. Master AI.
      </p>
      <p class="text-sm text-[var(--color-text-tertiary)]">
        &copy; {currentYear} AIByDM. Open source under MIT License.
      </p>
    </div>
  </div>
</footer>
