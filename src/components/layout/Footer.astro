---
const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, '')}`;

const repo = 'https://github.com/DipakMandlik/AIbyDM';

const columns = [
  {
    title: 'Product',
    links: [
      ['Learn', '/learn/'],
      ['Tools', '/tools/'],
      ['Games', '/games/'],
      ['Exams', '/exams/'],
      ['Newsletter', '/newsletter/'],
    ],
  },
  {
    title: 'Open Source',
    links: [
      ['GitHub', repo],
      ['Discussions', `${repo}/discussions`],
      ['Contributing', `${repo}/blob/main/CONTRIBUTING.md`],
      ['Issues', `${repo}/issues`],
      ['License', `${repo}/blob/main/LICENSE`],
    ],
  },
];

const currentYear = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-shell">
    <div class="footer-main">
      <div class="footer-brand">
        <a href={withBase('/')} class="brand-mark" aria-label="AIByDM home">
          <span>AI</span>
          <strong>AIByDM</strong>
        </a>
        <p>
          A premium open-source AI engineering platform for learning, tools, games, and community.
        </p>
      </div>

      {
        columns.map((column) => (
          <nav aria-label={column.title}>
            <h3>{column.title}</h3>
            {column.links.map(([label, href]) => {
              const external = href.startsWith('https://');
              return (
                <a
                  href={external ? href : withBase(href)}
                  target={external ? '_blank' : undefined}
                  rel={external ? 'noopener noreferrer' : undefined}
                >
                  {label}
                </a>
              );
            })}
          </nav>
        ))
      }
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} AIByDM. Open source under MIT License.</p>
      <div>
        <a href={`${repo}/blob/main/LICENSE`} target="_blank" rel="noopener noreferrer">License</a>
        <a href={repo} target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  document.querySelectorAll('[data-newsletter-form]').forEach((form) => {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const button = form.querySelector('button');
      if (button) button.textContent = 'Joined';
    });
  });
</script>
