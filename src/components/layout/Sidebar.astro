---
import {
  Home,
  Map,
  BookOpen,
  FlaskConical,
  GraduationCap,
  FolderGit2,
  Boxes,
  LayoutGrid,
  GitCompare,
  Upload,
  Gamepad2,
  Swords,
  Trophy,
  Award,
  FileText,
  Database,
  Timer,
  Library,
  Mail,
  Newspaper,
  Users,
  CalendarDays,
  Star,
} from 'lucide-react';
import type { LucideIcon } from 'lucide-react';

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, '')}`;

type Item = { label: string; href: string; icon: LucideIcon };
type Group = { label?: string; items: Item[] };

const groups: Group[] = [
  {
    items: [{ label: 'Home', href: withBase('/'), icon: Home }],
  },
  {
    label: 'Learn',
    items: [
      { label: 'Roadmap', href: withBase('/learn/'), icon: Map },
      { label: 'Courses', href: withBase('/learn/'), icon: BookOpen },
      { label: 'Hands-on Labs', href: withBase('/learn/'), icon: FlaskConical },
      { label: 'Tutorials', href: withBase('/learn/'), icon: GraduationCap },
      { label: 'Projects', href: withBase('/learn/'), icon: FolderGit2 },
    ],
  },
  {
    label: 'Tools',
    items: [
      { label: 'AI Tools Directory', href: withBase('/tools/'), icon: Boxes },
      { label: 'Categories', href: withBase('/tools/'), icon: LayoutGrid },
      { label: 'Compare Tools', href: withBase('/tools/'), icon: GitCompare },
      { label: 'Submit a Tool', href: withBase('/tools/'), icon: Upload },
    ],
  },
  {
    label: 'Games',
    items: [
      { label: 'Games Zone', href: withBase('/games/'), icon: Gamepad2 },
      { label: 'Challenges', href: withBase('/games/'), icon: Swords },
      { label: 'Leaderboards', href: withBase('/games/'), icon: Trophy },
      { label: 'Achievements', href: withBase('/games/'), icon: Award },
    ],
  },
  {
    label: 'Exams',
    items: [
      { label: 'Practice Exams', href: withBase('/exams/'), icon: FileText },
      { label: 'Question Bank', href: withBase('/exams/'), icon: Database },
      { label: 'Mock Tests', href: withBase('/exams/'), icon: Timer },
      { label: 'Study Materials', href: withBase('/exams/'), icon: Library },
    ],
  },
  {
    label: 'Resources',
    items: [
      { label: 'Newsletter', href: withBase('/newsletter/'), icon: Mail },
      { label: 'Blog', href: withBase('/newsletter/'), icon: Newspaper },
      {
        label: 'Community',
        href: 'https://github.com/DipakMandlik/AIbyDM/discussions',
        icon: Users,
      },
      { label: 'Events', href: withBase('/newsletter/'), icon: CalendarDays },
    ],
  },
];

const currentPath = Astro.url.pathname;
const homeHref = withBase('/');

function isActive(href: string) {
  if (href.startsWith('http')) return false;
  if (href === homeHref) return currentPath === homeHref;
  return currentPath.startsWith(href);
}
---

<aside class="app-sidebar" id="app-sidebar" aria-label="Primary">
  <a href={homeHref} class="sidebar-brand" aria-label="AIByDM home">
    <span>AI</span>
    <strong>AIByDM</strong>
  </a>

  <nav class="sidebar-nav" aria-label="Sidebar navigation">
    {
      groups.map((group) => (
        <div class="sidebar-group">
          {group.label && <p class="sidebar-group-label">{group.label}</p>}
          {group.items.map((item) => {
            const external = item.href.startsWith('http');
            const Icon = item.icon;
            return (
              <a
                href={item.href}
                class:list={['sidebar-link', isActive(item.href) && 'is-active']}
                target={external ? '_blank' : undefined}
                rel={external ? 'noopener noreferrer' : undefined}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                <Icon size={18} aria-hidden="true" />
                <span>{item.label}</span>
              </a>
            );
          })}
        </div>
      ))
    }
  </nav>

  <a
    class="sidebar-star"
    href="https://github.com/DipakMandlik/AIbyDM"
    target="_blank"
    rel="noopener noreferrer"
  >
    <Star size={18} aria-hidden="true" />
    <span>
      <strong>Star on GitHub</strong>
      <small>Show your support</small>
    </span>
  </a>
</aside>

<div class="sidebar-scrim" id="sidebar-scrim" hidden></div>
