---
interface Props {
  href?: string;
  class?: string;
}

const { href, class: className } = Astro.props;

const Tag = href ? 'a' : 'div';

const baseStyles = [
  'block rounded-xl border border-[var(--color-border)]',
  'bg-[var(--color-bg-surface)]',
  'transition-all duration-200 ease-out',
  className,
];

const interactiveStyles = href
  ? 'hover:border-[var(--color-border-hover)] hover:-translate-y-0.5 hover:shadow-lg hover:shadow-black/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--color-bg-base)]'
  : '';
---

<Tag class:list={[baseStyles, interactiveStyles]} {...href ? { href } : {}}>
  <slot />
</Tag>
