---
interface Props {
  variant?:
    | 'default'
    | 'learn'
    | 'tools'
    | 'games'
    | 'exams'
    | 'newsletter'
    | 'success'
    | 'warning'
    | 'error';
  size?: 'sm' | 'md';
  class?: string;
}

const { variant = 'default', size = 'sm', class: className } = Astro.props;

const variantStyles: Record<string, string> = {
  default:
    'bg-[var(--color-bg-elevated)] text-[var(--color-text-secondary)] border-[var(--color-border)]',
  learn:
    'bg-[color-mix(in_srgb,var(--color-learn)_15%,transparent)] text-[var(--color-learn)] border-[color-mix(in_srgb,var(--color-learn)_30%,transparent)]',
  tools:
    'bg-[color-mix(in_srgb,var(--color-tools)_15%,transparent)] text-[var(--color-tools)] border-[color-mix(in_srgb,var(--color-tools)_30%,transparent)]',
  games:
    'bg-[color-mix(in_srgb,var(--color-games)_15%,transparent)] text-[var(--color-games)] border-[color-mix(in_srgb,var(--color-games)_30%,transparent)]',
  exams:
    'bg-[color-mix(in_srgb,var(--color-exams)_15%,transparent)] text-[var(--color-exams)] border-[color-mix(in_srgb,var(--color-exams)_30%,transparent)]',
  newsletter:
    'bg-[color-mix(in_srgb,var(--color-newsletter)_15%,transparent)] text-[var(--color-newsletter)] border-[color-mix(in_srgb,var(--color-newsletter)_30%,transparent)]',
  success:
    'bg-[color-mix(in_srgb,#22c55e_15%,transparent)] text-[#22c55e] border-[color-mix(in_srgb,#22c55e_30%,transparent)]',
  warning:
    'bg-[color-mix(in_srgb,#eab308_15%,transparent)] text-[#eab308] border-[color-mix(in_srgb,#eab308_30%,transparent)]',
  error:
    'bg-[color-mix(in_srgb,#ef4444_15%,transparent)] text-[#ef4444] border-[color-mix(in_srgb,#ef4444_30%,transparent)]',
};

const sizeStyles: Record<string, string> = {
  sm: 'px-2 py-0.5 text-xs',
  md: 'px-2.5 py-1 text-sm',
};
---

<span
  class:list={[
    'inline-flex items-center rounded-full border leading-none font-medium whitespace-nowrap',
    variantStyles[variant],
    sizeStyles[size],
    className,
  ]}
>
  <slot />
</span>
